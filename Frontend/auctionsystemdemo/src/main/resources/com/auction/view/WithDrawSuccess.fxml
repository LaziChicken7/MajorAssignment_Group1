<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.DepositController"
      spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT">
        <Label text="&lt; Nạp tiền" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="card" spacing="30" alignment="CENTER_LEFT">
        <AnchorPane style="-fx-background-color: #0A439D; -fx-background-radius: 15;" prefWidth="350" prefHeight="200">
            <Label text="VISA" AnchorPane.bottomAnchor="15" AnchorPane.rightAnchor="20" textFill="white" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </AnchorPane>

        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <HBox spacing="10">
                <Label text="Số tài khoản:" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="1023456789" style="-fx-font-size: 20px;"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Số dư" style="-fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150"/>
                <TextField text="144.250.000 VND" editable="false" style="-fx-background-radius: 20; -fx-font-size: 16px; -fx-alignment: center;" prefWidth="250"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Số dư đóng băng" style="-fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150"/>
                <Label text="1.275.000.000 VND" styleClass="auction-price" style="-fx-font-size: 16px;" prefWidth="250" alignment="CENTER"/>
            </HBox>
        </VBox>
    </HBox>

    <VBox fx:id="contentArea" spacing="20" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);"
          alignment="CENTER">

        <padding>
            <Insets top="40" right="20" bottom="40" left="20"/>
        </padding>

        <StackPane>
            <Circle radius="50" fill="#00C853"/>
            <Label text="✔" textFill="white" style="-fx-font-size: 50px; -fx-font-weight: bold;"/>
        </StackPane>

        <Label text="Rút tiền thành công" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #00C853;"/>

        <Button text="Quay lại" onAction="#handleBackToWallet"
                style="-fx-background-color: #0A439D; -fx-text-fill: white; -fx-font-size: 20px;
                       -fx-background-radius: 25; -fx-padding: 10 50; -fx-cursor: hand;"/>
    </VBox>
</VBox>