<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<HBox prefHeight="700.0" prefWidth="1000.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.RegisterController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <children>
        <!-- BÊN TRÁI: PANEL THƯƠNG HIỆU (Đồng bộ với Login) -->
        <VBox alignment="CENTER" prefWidth="400.0" spacing="30.0" styleClass="sidebar" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <!-- Icon Búa đấu giá giả lập -->
                        <Label text="⚖" textFill="white">
                            <font><Font name="System Bold" size="80.0" /></font>
                        </Label>
                        <Label text="AUCTION PRO" textFill="white">
                            <font><Font name="Segoe UI Black" size="32.0" /></font>
                        </Label>
                        <Separator maxWidth="150" opacity="0.3" />
                        <Label text="Hệ thống đấu giá trực tuyến" textFill="white">
                            <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <Label text="Tham gia cộng đồng đấu giá ngay để nhận những ưu đãi tốt nhất."
                       textAlignment="CENTER" textFill="#b2c7e6" wrapText="true">
                    <font><Font name="Segoe UI Italic" size="14.0" /></font>
                    <VBox.margin><Insets left="40.0" right="40.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- BÊN PHẢI: FORM ĐĂNG KÝ (Nằm trong Card) -->
        <StackPane prefWidth="600.0" HBox.hgrow="ALWAYS">
            <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
            <children>
                <!-- Thẻ Card trắng dùng class trong CSS của bạn -->
                <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="450.0" spacing="15.0" styleClass="card">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Tạo tài khoản mới">
                                    <font><Font name="Segoe UI Bold" size="28.0" /></font>
                                </Label>
                                <Label text="Bắt đầu hành trình đấu giá của bạn" textFill="#7f8c8d" />
                            </children>
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Họ và tên" style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtFullName" prefHeight="40.0" promptText="Nhập họ và tên..." styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Email" style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtEmail" prefHeight="40.0" promptText="example@gmail.com" styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Tên đăng nhập" style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Chọn tên đăng nhập..." styleClass="input-field" />
                            </children>
                        </VBox>

                        <HBox spacing="15.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Mật khẩu" style="-fx-font-weight: bold;" />
                                        <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="Mật khẩu" styleClass="input-field" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Xác nhận" style="-fx-font-weight: bold;" />
                                        <PasswordField fx:id="txtConfirmPassword" prefHeight="40.0" promptText="Nhập lại" styleClass="input-field" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Button maxWidth="Infinity" onAction="#handleRegister" prefHeight="45.0" styleClass="btn-primary" text="ĐĂNG KÝ NGAY">
                            <VBox.margin><Insets top="15.0" /></VBox.margin>
                        </Button>

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Đã có tài khoản?" />
                                <Hyperlink onAction="#goToLogin" style="-fx-text-fill: #0A439D; -fx-font-weight: bold;" text="Đăng nhập" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
                    </padding>
                </VBox>
            </children>
        </StackPane>
    </children>
</HBox>