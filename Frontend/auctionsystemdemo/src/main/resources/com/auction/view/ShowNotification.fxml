<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.auction.controller.NotificationController"
           style="-fx-background-color: rgba(0, 0, 0, 0.4);">

    <VBox alignment="TOP_CENTER" spacing="20"
          style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10);"
          maxWidth="700" maxHeight="350">

        <padding>
            <Insets top="40" right="40" bottom="30" left="40"/>
        </padding>

        <Label text="Sản phẩm đấu giá thành công: SP17 - Auction Item 17 - Giá tiền: 12.725.000 VND"
               style="-fx-font-size: 18px; -fx-text-fill: #333333;"
               wrapText="true" alignment="TOP_LEFT" maxWidth="Infinity"/>

        <Region VBox.vgrow="ALWAYS" />

        <Button text="Đóng" onAction="#handleClose"
                style="-fx-background-color: #0A56D2; -fx-text-fill: white; -fx-font-size: 18px; -fx-background-radius: 25; -fx-padding: 8 40; -fx-cursor: hand;" />
    </VBox>
</StackPane>