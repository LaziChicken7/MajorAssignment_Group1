<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<?import javafx.geometry.Insets?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.WithDrawController"
      spacing="30" alignment="CENTER" prefHeight="350"
      style="-fx-background-color: white; -fx-background-radius: 30; -fx-border-radius: 30; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 10);">

    <padding>
        <Insets top="20" right="40" bottom="20" left="40"/>
    </padding>

    <Label text="Số tiền muốn rút?" style="-fx-font-size: 25px; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="15">
        <TextField fx:id="amountField" style="-fx-font-size: 20px; -fx-background-radius: 15; -fx-padding: 10;"/>
        <Label text="VND" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="30">
        <Button text="Xác nhận" onAction="#handleWithdrawConfirm"
                style="-fx-background-color: #00C853; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 12 40; -fx-cursor: hand;"/>

        <Button text="Hủy bỏ" onAction="#handleCancel"
                style="-fx-background-color: #FF0000; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 12 40; -fx-cursor: hand;"/>
    </HBox>
</VBox>