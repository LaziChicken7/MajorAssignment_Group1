<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.auction.controller.NotificationController" spacing="20" style="-fx-background-color: transparent;">
    <HBox alignment="CENTER_LEFT">
        <Label text="&lt; Thông báo" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <padding>
            <Insets top="30" right="20" bottom="30" left="20"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="noti-item"
              style="-fx-background-color: #f8f9fa; -fx-background-radius: 15; -fx-padding: 15;">
            <Label text="Xác thực giao dịch: SP01 - Auction Item 01 - Giá tiền: 1.725.000VND"
                   style="-fx-font-size: 16px;"/>

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button styleClass="btn-circle-success" style="-fx-font-size: 18px;" text="✔" onAction="#handleAcceptNotification"/>
                <Button styleClass="btn-circle-danger" style="-fx-font-size: 18px;" text="✖" onAction="#handleRejectNotification"/>
                <Button styleClass="btn-circle-info" style="-fx-font-size: 26px;" text="⋯" onAction="#handleMoreOptions"/>
            </HBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="noti-item"
              style="-fx-background-color: #f8f9fa; -fx-background-radius: 15; -fx-padding: 15;">
            <Label text="Sản phẩm đấu giá thành công: SP17 - Auction Item 17 - Giá tiền: 1..."
                   style="-fx-font-size: 16px;"/>

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button styleClass="btn-circle-danger" style="-fx-font-size: 18px;" text="☒" onAction="#handleDeleteNotification"/>
                <Button styleClass="btn-circle-info" style="-fx-font-size: 26px;" text="⋯" onAction="#handleMoreOptions"/>
            </HBox>
        </HBox>
    </VBox>
</VBox>