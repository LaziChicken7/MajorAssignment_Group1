<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-background-color: #f4f4f4; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.MyAuctionListController">

    <!-- Header: Chứa tiêu đề và nút Thêm -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="<" style="-fx-font-size: 18; -fx-cursor: hand;" />
        <Label text="Sản phẩm đấu giá của tôi" style="-fx-font-size: 20; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />

        <!-- NÚT QUAN TRỌNG: Bấm vào đây để sang trang AddProduct -->
        <Button onAction="#goToAddProduct" text="Thêm sản phẩm"
                style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;"/>
    </HBox>

    <!-- Danh sách hiển thị sản phẩm -->
    <ListView fx:id="myAuctionListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;" />
</VBox>