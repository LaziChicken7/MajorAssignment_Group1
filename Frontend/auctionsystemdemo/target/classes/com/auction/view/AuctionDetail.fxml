<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionDetailController">
    <children>
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20;">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-font-weight: bold;" text="&lt; Đấu giá" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #004aad; -fx-font-weight: bold;" text="Số dư: 144.250.000 VND" />
                    </children>
                </HBox>
                <HBox spacing="30.0">
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <ImageView fx:id="imgProduct" fitHeight="250.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <!-- Tạm thời để trống hoặc dùng link online để Scene Builder không lỗi -->
                                        <Image url="https://via.placeholder.com/300" />
                                    </image>
                                </ImageView>
                                <Label text="1/10" />
                            </children>
                        </VBox>
                        <VBox spacing="15.0" style="-fx-background-color: #f9f9f9; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label fx:id="lblId" style="-fx-font-weight: bold; -fx-font-size: 18;" text="SP1" />
                                        <Label fx:id="lblName" style="-fx-font-size: 18;" text="Auction Name 1" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblTime" style="-fx-background-color: #ffbd59; -fx-padding: 5 15; -fx-background-radius: 10;" text="00:01:12" />
                                    </children>
                                </HBox>
                                <GridPane hgap="20.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Label text="Giá ban đầu:" />
                                        <Label fx:id="lblStartPrice" style="-fx-text-fill: white; -fx-background-color: #004aad; -fx-padding: 2 15; -fx-background-radius: 10;" text="1.000.000 VND" GridPane.columnIndex="1" />
                                        <Label text="Giá bạn đấu giá hiện tại:" GridPane.rowIndex="1" />
                                        <Label fx:id="lblMyPrice" style="-fx-text-fill: white; -fx-background-color: #2ecc71; -fx-padding: 2 15; -fx-background-radius: 10;" text="0 VND" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                                <Label style="-fx-font-weight: bold;" text="Giá hiện tại:" />
                                <Label fx:id="lblCurrentPrice" alignment="CENTER" maxWidth="Infinity" style="-fx-background-color: #ff7e33; -fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 20;" text="1.273.000 VND" />
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Label text="+" />
                                        <TextField fx:id="txtBidInput" prefWidth="150.0" promptText="Nhập giá..." />
                                        <Button onAction="#showConfirmPopup" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-font-weight: bold;" text="Đấu giá" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <TextArea fx:id="txtDescription" editable="false" prefHeight="100.0" text="Mô tả sản phẩm..." wrapText="true" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>

        <!-- Popup (Ẩn mặc định) -->
        <VBox fx:id="panePopup" alignment="CENTER" visible="false" style="-fx-background-color: rgba(0,0,0,0.5);">
            <children>
                <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-max-width: 400;">
                    <children>
                        <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Xác nhận đấu giá" />
                        <Label fx:id="lblConfirmAmount" style="-fx-font-size: 22; -fx-font-weight: bold;" text="2.125.000 VND" />
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <Button onAction="#processBid" prefWidth="120.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Xác nhận" />
                                <Button onAction="#hidePopup" prefWidth="120.0" style="-fx-background-color: #ff3b30; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="Hủy bỏ" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>