<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="20" style="-fx-background-color: transparent;">
    <HBox alignment="CENTER_LEFT">
        <Label text="&lt; Đấu giá" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Số dư: 144.250.000 VND" styleClass="auction-price" style="-fx-font-size: 16px;" />
    </HBox>

    <HBox spacing="20">
        <!-- Cột trái: Ảnh sản phẩm -->
        <VBox styleClass="card" alignment="CENTER" spacing="10" prefWidth="400">
            <HBox alignment="CENTER" spacing="10">
                <Button text="&lt;" styleClass="icon-btn" style="-fx-font-size: 30px;"/>
                <StackPane styleClass="image-placeholder" prefWidth="250" prefHeight="250">
                    <Label text="🖼" style="-fx-font-size: 80px; -fx-text-fill: white;"/>
                </StackPane>
                <Button text="&gt;" styleClass="icon-btn" style="-fx-font-size: 30px;"/>
            </HBox>
            <Label text="1/10" style="-fx-font-size: 14px;"/>
        </VBox>

        <!-- Cột phải: Thông tin & Đấu giá -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15">
            <HBox><Label text="SP1" styleClass="auction-title" prefWidth="50"/><Label text="Auction Name 1" styleClass="auction-title" HBox.hgrow="ALWAYS"/><Region HBox.hgrow="ALWAYS"/><Label text="00:01:12" styleClass="auction-time"/></HBox>

            <HBox spacing="10" alignment="CENTER_LEFT"><Label text="Giá ban đầu:" prefWidth="150"/><Label text="1.000.000 VND" styleClass="auction-price"/></HBox>
            <HBox spacing="10" alignment="CENTER_LEFT"><Label text="Giá bạn đấu hiện tại:" prefWidth="150"/><Label text="0 VND" style="-fx-background-color: #00C853; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 15; -fx-font-weight: bold;"/></HBox>
            <HBox spacing="10" alignment="CENTER_LEFT"><Label text="Giá hiện tại:" prefWidth="150"/>
                <Label text="1.273.000 VND" style="-fx-background-color: #FF8C00; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 20; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-margin-top: 20px;">
                <Label text="+" style="-fx-font-size: 20px;"/>
                <TextField text="2125000" styleClass="input-field" prefWidth="150"/>
                <Label text="VND" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                <Button text="⬆" styleClass="btn-success" style="-fx-background-radius: 50;"/>
                <Button text="⬇" styleClass="btn-danger" style="-fx-background-radius: 50;"/>
                <Button text="Đấu giá" styleClass="btn-primary" />
            </HBox>
        </VBox>
    </HBox>

    <VBox styleClass="card">
        <Label text="Mô tả sản phẩm" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <TextArea text="Lorem Ipsum is simply dummy text..." wrapText="true" editable="false" prefRowCount="4" style="-fx-background-color: transparent; -fx-border-width: 0;"/>
    </VBox>
</VBox>