<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" styleClass="auction-card" stylesheets="@../style/style.css"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionItemController">
    <children>
        <!-- Dòng 1: ID, Tên và Giá hiện tại -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <HBox spacing="10" minWidth="200">
                    <children>
                        <Label fx:id="lblId" text="SP1" style="-fx-font-weight: bold; -fx-font-size: 15;" />
                        <Label fx:id="lblName" text="Tên sản phẩm" style="-fx-font-size: 15;" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Giá hiện tại:" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    <Label fx:id="lblPrice" text="0 VND" styleClass="price-pill" />
                </HBox>
            </children>
        </HBox>

        <!-- Dòng 2: Trạng thái và Thời gian còn lại -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <HBox spacing="5">
                    <children>
                        <Label text="Trạng thái hiện tại:" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #95a5a6;" />
                        <Label fx:id="lblStatus" text="RUNNING" style="-fx-font-weight: bold;" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Thời gian còn lại:" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
                    <Label fx:id="lblTime" text="00:00:00" styleClass="time-pill" />
                </HBox>
            </children>
        </HBox>
    </children>
</VBox>