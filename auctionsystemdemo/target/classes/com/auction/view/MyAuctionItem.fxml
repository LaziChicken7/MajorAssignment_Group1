<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.MyAuctionItemController"
      spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">

    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label fx:id="lblId" text="SP1" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #000;"/>
        <Label fx:id="lblName" text="Auction Name" style="-fx-font-size: 18px; -fx-text-fill: #333;"/>
    </HBox>

    <HBox alignment="CENTER_LEFT">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Giá hiện tại:" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <Label fx:id="lblPrice" text="0 VND" style="-fx-background-color: #3b5998; -fx-text-fill: white; -fx-padding: 5 20; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Thời gian:" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <Label fx:id="lblTime" text="00:00:00" style="-fx-background-color: #f1c40f; -fx-text-fill: #000; -fx-padding: 5 20; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </HBox>
    </HBox>

    <!-- DÒNG TRẠNG THÁI VÀ NÚT BẤT ĐẦU -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Trạng thái:" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
        <Label fx:id="lblStatus" text="OPEN" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Nút Bắt đầu phiên (Mặc định ẩn) -->
        <Button fx:id="btnStartAuction" text="▶ Bắt đầu phiên đấu giá" onAction="#handleStartAuction"
                visible="false" managed="false"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 5 15;"/>
    </HBox>
</VBox>