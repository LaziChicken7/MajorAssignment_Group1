<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Nền Root y hệt Wallet.fxml -->
<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.WithDrawController"
      spacing="20" style="-fx-background-color: transparent;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT">
        <Label text="&lt; Rút tiền" onMouseClicked="#handleBackToWallet" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- THẺ VISA & THÔNG TIN (Dùng styleClass="card" chuẩn) -->
    <HBox styleClass="card" spacing="30" alignment="CENTER_LEFT">
        <AnchorPane style="-fx-background-color: #0A439D; -fx-background-radius: 15;" prefWidth="350" prefHeight="200">
            <Label text="VISA" AnchorPane.bottomAnchor="15" AnchorPane.rightAnchor="20" textFill="white" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </AnchorPane>

        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <HBox spacing="10">
                <Label text="Số tài khoản:" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label fx:id="lblBankAccount" text="Đang tải..." style="-fx-font-size: 20px; -fx-text-fill: #333;"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Số dư" style="-fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150"/>
                <TextField fx:id="balanceField" text="Đang tải..." editable="false" style="-fx-background-radius: 20; -fx-font-size: 16px; -fx-alignment: center;" prefWidth="210"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Số dư đóng băng" style="-fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150"/>
                <Label fx:id="lblFrozenBalance" text="Đang tải..." styleClass="auction-price" style="-fx-font-size: 16px;" prefWidth="250" alignment="CENTER"/>
            </HBox>
        </VBox>
    </HBox>

    <!-- KHU VỰC NHẬP TIỀN BÊN DƯỚI (Dùng styleClass="card" chuẩn) -->
    <VBox spacing="30" VBox.vgrow="ALWAYS" styleClass="card" alignment="CENTER">

        <Label text="Số tiền muốn rút?" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

        <HBox alignment="CENTER" spacing="15">
            <TextField fx:id="amountField" promptText="0" style="-fx-font-size: 20px; -fx-background-radius: 15; -fx-padding: 10;" prefWidth="300" alignment="CENTER"/>
            <Label text="VND" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>

        <HBox alignment="CENTER" spacing="30">
            <Button text="Xác nhận" onAction="#handleWithdrawConfirm" style="-fx-background-color: #00C853; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 10 40; -fx-cursor: hand;"/>
            <Button text="Hủy bỏ" onAction="#handleCancel" style="-fx-background-color: #FF0000; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 10 40; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</VBox>