<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>

<!-- Thay đổi Root thành VBox và spacing 20 để khớp với tỷ lệ màn hình của Wallet -->
<VBox spacing="20" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.chat.ChatController">

    <!-- HEADER: Nút quay lại và Tiêu đề giống hệt màn hình Wallet -->
    <HBox alignment="CENTER_LEFT">
        <!-- Thêm sự kiện onMouseClicked="#goBack" và đổi con trỏ chuột thành hình bàn tay -->
        <HBox spacing="5" styleClass="title-container" onMouseClicked="#goBack" style="-fx-cursor: hand;">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label styleClass="back-title" text="Tin nhắn" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- LỚP CHÍNH: KHUNG CHAT (Giãn hết phần còn lại của màn hình) -->
    <HBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">

        <!-- CỘT TRÁI: DANH SÁCH BẠN BÈ -->
        <!-- Đặt độ rộng cố định và VBox.vgrow="ALWAYS" để card này dài tới cuối màn hình -->
        <VBox prefWidth="320" styleClass="card" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5);">

            <!-- Header cột trái -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 20; -fx-border-color: #ecf0f1; -fx-border-width: 0 0 1 0;">
                <SVGPath content="M 21 15 a 2 2 0 0 1 -2 2 H 7 l -4 4 V 5 a 2 2 0 0 1 2 -2 h 14 a 2 2 0 0 1 2 2 z" fill="#3b5998" scaleX="1.2" scaleY="1.2"/>
                <Label text="Đoạn chat" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            </HBox>

            <!-- Ô tìm kiếm (Giao diện Messenger style) -->
            <HBox style="-fx-padding: 15 15 5 15;">
                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" style="-fx-background-color: #f0f2f5; -fx-background-radius: 20; -fx-padding: 0 15;">
                    <!-- Icon Kính lúp -->
                    <SVGPath content="M 15.5 14 h -.79 l -.28 -.27 A 6.471 6.471 0 0 0 16 9.5 A 6.5 6.5 0 1 0 9.5 16 c 1.61 0 3.09 -.59 4.23 -1.57 l .27 .28 v .79 l 5 4.99 L 20.49 19 l -4.99 -5 z m -6 0 C 7.01 14 5 11.99 5 9.5 S 7.01 5 9.5 5 S 14 7.01 14 9.5 S 11.99 14 9.5 14 z" fill="#8d949e" scaleX="0.8" scaleY="0.8"/>
                    <!-- Khai báo fx:id="txtSearchFriend" để xử lý logic -->
                    <TextField fx:id="txtSearchFriend" promptText="Tìm kiếm bạn bè..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 10; -fx-font-size: 14px; -fx-prompt-text-fill: #8d949e; -fx-text-fill: #050505;"/>
                </HBox>
            </HBox>

            <!-- Danh sách -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="vboxFriends" spacing="8" style="-fx-padding: 10 15 20 15;"/>
                </content>
            </ScrollPane>
        </VBox>

        <!-- CỘT PHẢI: KHUNG CHAT CHI TIẾT -->
        <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" styleClass="card" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5);">

            <!-- Header: Tên người đang chat -->
            <HBox fx:id="chatHeader" alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 15 25; -fx-border-color: #ecf0f1; -fx-border-width: 0 0 1 0; -fx-background-color: #fcfcfd; -fx-background-radius: 15 15 0 0;" visible="false" managed="false">
                <ImageView fx:id="imgChatAvatar" fitWidth="50" fitHeight="50"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="lblChatName" text="Tên bạn bè" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <!-- Chấm xanh Online -->
                        <SVGPath content="M 12 24 A 12 12 0 1 0 12 0 A 12 12 0 1 0 12 24 Z" fill="#2ecc71" scaleX="0.35" scaleY="0.35"/>
                        <Label text="Đang hoạt động" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                    </HBox>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Nút Tiện ích -->
                <HBox spacing="10">
                    <Button style="-fx-background-color: #f1f2f6; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                        <graphic>
                            <SVGPath content="M 22 16.92 v 3 a 2 2 0 0 1 -2.18 2 a 19.79 19.79 0 0 1 -8.63 -3.07 a 19.5 19.5 0 0 1 -6 -6 a 19.79 19.79 0 0 1 -3.07 -8.67 A 2 2 0 0 1 4.11 2 h 3 a 2 2 0 0 1 2 1.72 a 12.84 12.84 0 0 0 .7 2.81 a 2 2 0 0 1 -.45 2.11 L 8.09 9.91 a 16 16 0 0 0 6 6 l 1.27 -1.27 a 2 2 0 0 1 2.11 -.45 a 12.84 12.84 0 0 0 2.81 .7 A 2 2 0 0 1 22 16.92 z" fill="#3b5998" scaleX="0.6" scaleY="0.6"/>
                        </graphic>
                    </Button>
                    <Button style="-fx-background-color: #f1f2f6; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;">
                        <graphic>
                            <SVGPath content="M 12 22 c 5.523 0 10 -4.477 10 -10 S 17.523 2 12 2 S 2 6.477 2 12 s 4.477 10 10 10 z M 12 16 v -4 m 0 -4 h .01" stroke="#3b5998" strokeWidth="2" fill="TRANSPARENT" strokeLineCap="ROUND"/>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>

            <!-- Màn hình chờ -->
            <VBox fx:id="paneWaiting" alignment="CENTER" VBox.vgrow="ALWAYS" spacing="15">
                <SVGPath content="M 21 15 a 2 2 0 0 1 -2 2 H 7 l -4 4 V 5 a 2 2 0 0 1 2 -2 h 14 a 2 2 0 0 1 2 2 z" fill="#ecf0f1" scaleX="3.5" scaleY="3.5"/>
                <Label text="Chọn một đoạn chat hoặc bắt đầu cuộc trò chuyện mới" style="-fx-font-size: 16px; -fx-text-fill: #95a5a6; -fx-padding: 40 0 0 0;"/>
            </VBox>

            <!-- Khung chứa tin nhắn -->
            <ScrollPane fx:id="scrollMessages" fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS" visible="false" managed="false">
                <content>
                    <VBox fx:id="vboxMessages" spacing="12" style="-fx-padding: 20 25;"/>
                </content>
            </ScrollPane>

            <!-- Ô NHẬP LIỆU (Đã sửa lỗi cấu trúc) -->
            <HBox fx:id="paneInput" alignment="CENTER" spacing="15" style="-fx-padding: 15 25; -fx-border-color: #ecf0f1; -fx-border-width: 1 0 0 0; -fx-background-color: #fcfcfd; -fx-background-radius: 0 0 15 15;" visible="false" managed="false">

                <!-- Icon Dấu + (Hiển thị Menu đính kèm) -->
                <Button fx:id="btnAttachment" onAction="#showAttachmentMenu" style="-fx-background-color: #f0f2f5; -fx-background-radius: 50; -fx-min-width: 38; -fx-min-height: 38; -fx-cursor: hand;">
                    <graphic>
                        <SVGPath content="M 19 13 h -6 v 6 h -2 v -6 H 5 v -2 h 6 V 5 h 2 v 6 h 6 v 2 z" fill="#0A439D" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>

                <!-- Khung nhập text -->
                <TextField fx:id="txtMessage" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" styleClass="modern-input" style="-fx-background-radius: 25; -fx-padding: 12 20; -fx-font-size: 15px; -fx-background-color: #f1f2f6; -fx-border-color: transparent;" onAction="#sendMessage"/>

                <!-- Nút gửi -->
                <Button onAction="#sendMessage" style="-fx-background-color: #3b5998; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 45; -fx-min-height: 45; -fx-cursor: hand;">
                    <graphic>
                        <SVGPath content="M 22 2 L 11 13 M 22 2 L 15 22 L 11 13 L 2 9 L 22 2 z" stroke="white" strokeWidth="1.5" fill="TRANSPARENT" scaleX="0.8" scaleY="0.8" translateX="-2" translateY="1"/>
                    </graphic>
                </Button>
            </HBox>

        </VBox>
    </HBox>
</VBox>