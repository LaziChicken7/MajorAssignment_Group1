<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="20" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.chat.ChatController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="title-container" style="-fx-cursor: hand;">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label styleClass="back-title" text="Tin nhắn" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER_LEFT" spacing="15">
            <!-- Đổi sang dùng class btn-friend-list -->
            <Button text="Danh sách kết bạn" onAction="#showAllFriends" styleClass="btn-friend-list">
                <graphic>
                    <SVGPath content="M 16 11 c 1.66 0 2.99 -1.34 2.99 -3 S 17.66 5 16 5 s -3 1.34 -3 3 s 1.34 3 3 3 z m -8 0 c 1.66 0 2.99 -1.34 2.99 -3 S 9.66 5 8 5 S 5 6.34 5 8 s 1.34 3 3 3 z m 0 2 c -2.33 0 -7 1.17 -7 3.5 V 19 h 14 v -2.5 c 0 -2.33 -4.67 -3.5 -7 -3.5 z m 8 0 c -.29 0 -.62 .02 -.97 .05 c 1.16 .84 1.97 1.97 1.97 3.45 V 19 h 6 v -2.5 c 0 -2.33 -4.67 -3.5 -7 -3.5 z"
                             styleClass="icon-blue" scaleX="0.75" scaleY="0.75"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- LỚP CHÍNH: KHUNG CHAT -->
    <HBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">

        <!-- CỘT TRÁI: DANH SÁCH BẠN BÈ -->
        <!-- Đã gỡ bỏ inline background, dùng thẻ card có sẵn -->
        <VBox prefWidth="320" styleClass="card, chat-no-padding" VBox.vgrow="ALWAYS">

            <!-- Header cột trái -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="chat-border-bottom" style="-fx-padding: 20;">
                <SVGPath content="M 21 15 a 2 2 0 0 1 -2 2 H 7 l -4 4 V 5 a 2 2 0 0 1 2 -2 h 14 a 2 2 0 0 1 2 2 z" styleClass="icon-blue" scaleX="1.2" scaleY="1.2"/>
                <Label text="Đoạn chat" styleClass="chat-title-text"/>
            </HBox>

            <!-- Ô tìm kiếm -->
            <HBox style="-fx-padding: 15 15 5 15;">
                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" styleClass="chat-search-bg">
                    <SVGPath content="M 15.5 14 h -.79 l -.28 -.27 A 6.471 6.471 0 0 0 16 9.5 A 6.5 6.5 0 1 0 9.5 16 c 1.61 0 3.09 -.59 4.23 -1.57 l .27 .28 v .79 l 5 4.99 L 20.49 19 l -4.99 -5 z m -6 0 C 7.01 14 5 11.99 5 9.5 S 7.01 5 9.5 5 S 14 7.01 14 9.5 S 11.99 14 9.5 14 z" styleClass="icon-gray" scaleX="0.8" scaleY="0.8"/>
                    <TextField fx:id="txtSearchFriend" promptText="Tìm kiếm bạn bè..." HBox.hgrow="ALWAYS" styleClass="chat-search-input"/>
                </HBox>
            </HBox>

            <!-- Danh sách -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="vboxFriends" spacing="8" style="-fx-padding: 10 15 20 15;"/>
                </content>
            </ScrollPane>
        </VBox>

        <!-- CỘT PHẢI: KHUNG CHAT CHI TIẾT -->
        <VBox HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" styleClass="card, chat-no-padding">

            <!-- Header: Tên người đang chat -->
            <HBox fx:id="chatHeader" alignment="CENTER_LEFT" spacing="15" styleClass="chat-border-bottom, chat-header-bg" style="-fx-padding: 15 25;" visible="false" managed="false">
                <ImageView fx:id="imgChatAvatar" fitWidth="50" fitHeight="50"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="lblChatName" text="Tên bạn bè" styleClass="chat-title-text" style="-fx-font-size: 18px;"/>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <SVGPath content="M 12 24 A 12 12 0 1 0 12 0 A 12 12 0 1 0 12 24 Z" fill="#2ecc71" scaleX="0.35" scaleY="0.35"/>
                        <Label text="Đang hoạt động" styleClass="chat-subtitle-text"/>
                    </HBox>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <HBox spacing="10">
                    <Button styleClass="btn-circle-action">
                        <graphic>
                            <SVGPath content="M 22 16.92 v 3 a 2 2 0 0 1 -2.18 2 a 19.79 19.79 0 0 1 -8.63 -3.07 a 19.5 19.5 0 0 1 -6 -6 a 19.79 19.79 0 0 1 -3.07 -8.67 A 2 2 0 0 1 4.11 2 h 3 a 2 2 0 0 1 2 1.72 a 12.84 12.84 0 0 0 .7 2.81 a 2 2 0 0 1 -.45 2.11 L 8.09 9.91 a 16 16 0 0 0 6 6 l 1.27 -1.27 a 2 2 0 0 1 2.11 -.45 a 12.84 12.84 0 0 0 2.81 .7 A 2 2 0 0 1 22 16.92 z" styleClass="icon-blue" scaleX="0.6" scaleY="0.6"/>
                        </graphic>
                    </Button>
                    <Button fx:id="btnInfo" onAction="#showChatInfo" styleClass="btn-circle-action">
                        <graphic>
                            <SVGPath content="M 12 22 c 5.523 0 10 -4.477 10 -10 S 17.523 2 12 2 S 2 6.477 2 12 s 4.477 10 10 10 z M 12 16 v -4 m 0 -4 h .01" styleClass="icon-stroke-blue" strokeWidth="2" fill="TRANSPARENT" strokeLineCap="ROUND"/>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>

            <!-- Màn hình chờ -->
            <VBox fx:id="paneWaiting" alignment="CENTER" VBox.vgrow="ALWAYS" spacing="15">
                <SVGPath content="M 21 15 a 2 2 0 0 1 -2 2 H 7 l -4 4 V 5 a 2 2 0 0 1 2 -2 h 14 a 2 2 0 0 1 2 2 z" styleClass="chat-waiting-icon" scaleX="3.5" scaleY="3.5"/>
                <Label text="Chọn một đoạn chat hoặc bắt đầu cuộc trò chuyện mới" styleClass="chat-subtitle-text" style="-fx-font-size: 16px; -fx-padding: 40 0 0 0;"/>
            </VBox>

            <!-- Khung chứa tin nhắn -->
            <ScrollPane fx:id="scrollMessages" fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS" visible="false" managed="false">
                <content>
                    <VBox fx:id="vboxMessages" spacing="12" style="-fx-padding: 20 25;"/>
                </content>
            </ScrollPane>

            <!-- Ô NHẬP LIỆU -->
            <HBox fx:id="paneInput" alignment="CENTER" spacing="15" styleClass="chat-border-top, chat-footer-bg" style="-fx-padding: 15 25;" visible="false" managed="false">

                <Button fx:id="btnAttachment" onAction="#showAttachmentMenu" styleClass="btn-circle-action">
                    <graphic>
                        <SVGPath content="M 19 13 h -6 v 6 h -2 v -6 H 5 v -2 h 6 V 5 h 2 v 6 h 6 v 2 z" fill="#0A439D" scaleX="0.8" scaleY="0.8"/>
                    </graphic>
                </Button>

                <TextField fx:id="txtMessage" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" styleClass="chat-message-input" onAction="#sendMessage"/>

                <Button onAction="#sendMessage" styleClass="btn-send-message">
                    <graphic>
                        <SVGPath content="M 22 2 L 11 13 M 22 2 L 15 22 L 11 13 L 2 9 L 22 2 z" stroke="white" strokeWidth="1.5" fill="TRANSPARENT" scaleX="0.8" scaleY="0.8" translateX="-2" translateY="1"/>
                    </graphic>
                </Button>
            </HBox>

        </VBox>
    </HBox>
</VBox>