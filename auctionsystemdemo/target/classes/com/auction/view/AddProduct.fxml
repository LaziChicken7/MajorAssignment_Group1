<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-background-color: transparent; -fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.auction.controller.AddProductController">

    <Label onMouseClicked="#goBack" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;" text="&lt; Thêm sản phẩm" />

    <HBox spacing="30" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20;">
        <!-- Cột trái: Ảnh -->
        <VBox alignment="CENTER" spacing="15">
            <StackPane prefHeight="200" prefWidth="200" style="-fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-color: #f8f9fa;">
                <!-- Đây là nơi hiện ảnh -->
                <ImageView fx:id="productImage" fitHeight="190" fitWidth="190" pickOnBounds="true" preserveRatio="true" />
                <!-- Icon mặc định sẽ ẩn đi khi có ảnh -->
                <Label fx:id="lblPhotoIcon" style="-fx-font-size: 60px; -fx-text-fill: #ccc;" text="🖼" />
            </StackPane>
            <!-- Nút bấm tải ảnh -->
            <Button onAction="#handleUploadImage" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-background-radius: 5;" text="Tải ảnh lên" />
        </VBox>

        <!-- Cột phải: Form nhập liệu -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <HBox spacing="20">
                <TextField fx:id="txtProductId" prefWidth="150" promptText="Mã sản phẩm" />
                <TextField fx:id="txtProductName" promptText="Tên sản phẩm" HBox.hgrow="ALWAYS" />
            </HBox>
            <TextArea fx:id="txtDescription" prefRowCount="5" promptText="Mô tả sản phẩm" wrapText="true" />

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label prefWidth="150" style="-fx-font-weight: bold;" text="Số tiền ban đầu:" />
                <TextField fx:id="txtStartPrice" promptText="Số tiền đấu giá" HBox.hgrow="ALWAYS" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label prefWidth="150" style="-fx-font-weight: bold;" text="Thời gian kết thúc:" />
                <DatePicker fx:id="dpEnd" HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtEndTime" prefWidth="80" promptText="09:53" />
            </HBox>

            <HBox alignment="CENTER">
                <Button onAction="#handleConfirmAdd" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-padding: 10 40; -fx-background-radius: 20;" text="Xác nhận" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
