<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- Đã bỏ -fx-padding: 20; ở VBox gốc để mép ngoài sát bằng với Wallet -->
<VBox spacing="20" style="-fx-background-color: transparent;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AddProductController">

    <!-- HEADER: Đã bọc HBox giống hệt Wallet -->
    <HBox alignment="CENTER_LEFT">
        <Label onMouseClicked="#goBack" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-text-fill: #333333;" text="&lt; Thêm sản phẩm" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox spacing="30" styleClass="card" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">

        <!-- CỘT TRÁI: Ảnh -->
        <VBox alignment="CENTER" spacing="15">
            <StackPane prefHeight="250" prefWidth="250" style="-fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-color: #000000; -fx-background-radius: 10;">
                <ImageView fx:id="productImage" fitHeight="240" fitWidth="240" pickOnBounds="true" preserveRatio="true" />
                <Label fx:id="lblPhotoIcon" style="-fx-font-size: 80px; -fx-text-fill: white;" text="🖼" />
            </StackPane>
            <Button onAction="#handleUploadImage" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 30; -fx-font-weight: bold; -fx-cursor: hand;" text="Tải ảnh lên" />
        </VBox>

        <!-- CỘT PHẢI: Form -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">

            <!-- Tên sản phẩm (Trải dài hết 100%) -->
            <TextField fx:id="txtProductName" promptText="Tên sản phẩm" style="-fx-padding: 10; -fx-background-radius: 10; -fx-font-size: 14px; -fx-border-color: #333; -fx-border-radius: 10;"/>

            <!-- Mô tả -->
            <TextArea fx:id="txtDescription" prefRowCount="3" promptText="Mô tả sản phẩm" wrapText="true" style="-fx-padding: 10; -fx-background-radius: 10; -fx-font-size: 14px; -fx-border-color: #333; -fx-border-radius: 10;"/>

            <!-- Khung chọn Loại Sản phẩm -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Loại sản phẩm:" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                <ComboBox fx:id="cbItemType" prefWidth="250" style="-fx-font-size: 14px; -fx-background-radius: 10; -fx-border-color: #333; -fx-border-radius: 10; -fx-background-color: white;"/>
            </HBox>

            <!-- CÁC KHUNG THÔNG TIN ĐỘNG -->
            <!-- 1. Dành cho Nghệ thuật (ART) -->
            <VBox fx:id="vboxArt" spacing="10" visible="false" managed="false" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                <HBox spacing="15">
                    <TextField fx:id="txtAuthor" promptText="Tên tác giả" HBox.hgrow="ALWAYS" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-color: #ccc; -fx-border-radius: 8;"/>
                    <TextField fx:id="txtYear" promptText="Năm sáng tác (Ví dụ: 1998)" prefWidth="200" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-color: #ccc; -fx-border-radius: 8;"/>
                </HBox>
            </VBox>

            <!-- 2. Dành cho Điện tử (ELECTRONIC) -->
            <VBox fx:id="vboxElectronic" spacing="10" visible="false" managed="false" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                <HBox spacing="15">
                    <TextField fx:id="txtBrand" promptText="Thương hiệu (Ví dụ: Apple, Samsung)" HBox.hgrow="ALWAYS" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-color: #ccc; -fx-border-radius: 8;"/>
                    <TextField fx:id="txtWarranty" promptText="Bảo hành (tháng)" prefWidth="200" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-color: #ccc; -fx-border-radius: 8;"/>
                </HBox>
            </VBox>

            <!-- 3. Dành cho Phương tiện (VEHICLE) -->
            <VBox fx:id="vboxVehicle" spacing="10" visible="false" managed="false" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
                <HBox spacing="15">
                    <TextField fx:id="txtEngine" promptText="Loại động cơ (Điện, Xăng, Dầu)" HBox.hgrow="ALWAYS" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-color: #ccc; -fx-border-radius: 8;"/>
                    <TextField fx:id="txtMileage" promptText="Số Km đã đi" prefWidth="200" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-color: #ccc; -fx-border-radius: 8;"/>
                </HBox>
            </VBox>

            <GridPane vgap="15" hgap="15">
                <columnConstraints>
                    <ColumnConstraints minWidth="180" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Tiền khởi điểm:" style="-fx-font-weight: bold; -fx-font-size: 16px;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="txtStartPrice" promptText="Số tiền đấu giá" style="-fx-padding: 8; -fx-background-radius: 10; -fx-border-color: #333; -fx-border-radius: 10; -fx-font-size: 14px;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Lịch mở phiên:" style="-fx-font-weight: bold; -fx-font-size: 16px;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <DatePicker fx:id="dpStartDate" promptText="Ngày bắt đầu" style="-fx-font-size: 14px; -fx-border-color: #333; -fx-border-radius: 10;" prefHeight="35" prefWidth="180" />
                    <TextField fx:id="txtStartTime" promptText="Giờ (HH:mm)" style="-fx-padding: 8; -fx-background-radius: 10; -fx-border-color: #333; -fx-border-radius: 10; -fx-font-size: 14px;" prefWidth="120" />
                </HBox>

                <Label text="Lịch kết thúc:" style="-fx-font-weight: bold; -fx-font-size: 16px;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <HBox spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <DatePicker fx:id="dpEndDate" promptText="Ngày kết thúc" style="-fx-font-size: 14px; -fx-border-color: #333; -fx-border-radius: 10;" prefHeight="35" prefWidth="180" />
                    <TextField fx:id="txtEndTime" promptText="Giờ (HH:mm)" style="-fx-padding: 8; -fx-background-radius: 10; -fx-border-color: #333; -fx-border-radius: 10; -fx-font-size: 14px;" prefWidth="120" />
                </HBox>
            </GridPane>

            <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                <Button onAction="#handleConfirmAdd" styleClass="btn-primary" style="-fx-padding: 10 50; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand;" text="Xác nhận đưa lên sàn" />
            </HBox>
        </VBox>
    </HBox>
</VBox>