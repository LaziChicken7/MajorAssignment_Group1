<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?> <!-- ĐÃ IMPORT SVGPATH -->

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.WithDrawController" spacing="20" style="-fx-background-color: transparent;">

    <!-- HEADER ĐÃ ĐƯỢC CHUẨN HÓA -->
    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="back-btn-container" onMouseClicked="#handleBackToWallet">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label text="Rút tiền" styleClass="back-title" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="card" spacing="30" alignment="CENTER_LEFT">
        <AnchorPane style="-fx-background-color: #0A439D; -fx-background-radius: 15;" prefWidth="350" prefHeight="200">
            <Label text="VISA" AnchorPane.bottomAnchor="15" AnchorPane.rightAnchor="20" textFill="white" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </AnchorPane>

        <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <HBox spacing="10">
                <Label text="Số tài khoản:" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label fx:id="lblBankAccount" text="Đang tải..." style="-fx-font-size: 20px; -fx-text-fill: #333;"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Số dư" style="-fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150"/>
                <TextField fx:id="balanceField" text="Đang tải..." editable="false" style="-fx-background-radius: 20; -fx-font-size: 16px; -fx-alignment: center;" prefWidth="210"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Số dư đóng băng" style="-fx-font-size: 18px; -fx-font-weight: bold;" prefWidth="150"/>
                <Label fx:id="lblFrozenBalance" text="Đang tải..." styleClass="auction-price" style="-fx-font-size: 16px;" prefWidth="250" alignment="CENTER"/>
            </HBox>
        </VBox>
    </HBox>

    <VBox spacing="20" VBox.vgrow="ALWAYS" styleClass="card" alignment="CENTER">
        <padding><Insets top="40" right="20" bottom="40" left="20"/></padding>
        <StackPane>
            <Circle radius="50" fill="#FF0000"/>
            <Label text="✖" textFill="white" style="-fx-font-size: 50px; -fx-font-weight: bold;"/>
        </StackPane>
        <VBox alignment="CENTER" spacing="5">
            <Label text="Rút tiền thất bại" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #FF0000;"/>
            <Label text="Số dư không đủ" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #FF0000;"/>
        </VBox>
        <Button text="Quay lại" onAction="#handleBackToWallet" style="-fx-background-color: #0A439D; -fx-text-fill: white; -fx-font-size: 20px; -fx-background-radius: 25; -fx-padding: 10 50; -fx-cursor: hand;"/>
    </VBox>
</VBox>