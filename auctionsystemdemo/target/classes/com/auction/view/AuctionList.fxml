<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionController"
      spacing="20" style="-fx-background-color: transparent;">

    <!-- HEADER: Cấu trúc đẩy 2 bên y hệt Wallet.fxml -->
    <HBox alignment="CENTER_LEFT">

        <!-- BÊN TRÁI: Tiêu đề -->
        <Label text="&lt; Đấu giá" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand; -fx-text-fill: #333333;"/>

        <!-- Ở GIỮA: Khoảng trống đẩy dạt mọi thứ sang 2 lề -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- BÊN PHẢI: Nhóm nút Làm mới và Số dư (Tương đương nút Nạp/Rút bên Wallet) -->
        <HBox spacing="15" alignment="CENTER_LEFT">

            <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14px;"/>

            <!-- Khung Số dư nền xanh bo tròn -->
            <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #3b5998; -fx-background-radius: 20; -fx-padding: 6 20;">
                <Label text="Số dư:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                <Label fx:id="lblBalance" text="Đang tải..." style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
            </HBox>

        </HBox>
    </HBox>

    <!-- DANH SÁCH -->
    <ListView fx:id="auctionListView" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />

</VBox>