<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.profile.AdminController" spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="back-btn-container" onMouseClicked="#goBack">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label text="Trung tâm điều khiển Admin" styleClass="back-title" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🔄 Làm mới dữ liệu" onAction="#loadAllData" styleClass="btn-pill-refresh" style="-fx-padding: 8 20;" />
    </HBox>

    <TabPane styleClass="tab-pane-custom" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 0;">

        <!-- TAB 1: DANH SÁCH SẢN PHẨM -->
        <Tab text="Danh sách sản phẩm">
            <!-- Đặt TableView trực tiếp dưới Tab -->
            <TableView fx:id="tbItems" style="-fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colItemId" text="ID SP" prefWidth="120" />
                    <TableColumn fx:id="colItemName" text="Tên Sản Phẩm" prefWidth="250" />
                    <TableColumn fx:id="colItemType" text="Loại" prefWidth="120" />
                    <TableColumn fx:id="colItemPrice" text="Giá khởi điểm" prefWidth="150" />
                    <TableColumn fx:id="colItemSeller" text="Người Bán" prefWidth="150" />
                    <TableColumn fx:id="colItemActions" text="Hành Động" prefWidth="120" />
                </columns>
                <!-- Thêm placeholder cho đẹp khi bảng trống -->
                <placeholder>
                    <Label text="Không có sản phẩm nào" style="-fx-text-fill: #95a5a6; -fx-font-size: 16px;"/>
                </placeholder>
            </TableView>
        </Tab>

        <!-- TAB 2: QUẢN LÝ ĐẤU GIÁ -->
        <Tab text="Quản lý đấu giá">
            <TableView fx:id="tbAuctions" style="-fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colAucId" text="Mã Phiên" prefWidth="120" />
                    <TableColumn fx:id="colAucProduct" text="Sản Phẩm" prefWidth="220" />
                    <TableColumn fx:id="colAucHighestBid" text="Giá Cao Nhất" prefWidth="150" />
                    <TableColumn fx:id="colAucStatus" text="Trạng Thái" prefWidth="120" />
                    <TableColumn fx:id="colAucWinner" text="Người Thắng" prefWidth="150" />
                    <TableColumn fx:id="colAucActions" text="Hành Động" prefWidth="150" />
                </columns>
                <placeholder>
                    <Label text="Không có phiên đấu giá nào" style="-fx-text-fill: #95a5a6; -fx-font-size: 16px;"/>
                </placeholder>
            </TableView>
        </Tab>

        <!-- TAB 3: QUẢN LÝ NGƯỜI DÙNG -->
        <Tab text="Quản lý người dùng">
            <TableView fx:id="tbUsers" style="-fx-font-size: 14px;">
                <columns>
                    <TableColumn fx:id="colUserCode" text="Mã User" prefWidth="100" />
                    <TableColumn fx:id="colUsername" text="Username" prefWidth="180" />
                    <TableColumn fx:id="colUserFullName" text="Họ tên" prefWidth="150" />
                    <TableColumn fx:id="colUserRole" text="Vai trò" prefWidth="120" />
                    <TableColumn fx:id="colUserStatus" text="Trạng thái" prefWidth="120" />
                    <TableColumn fx:id="colUserActions" text="Hành động" prefWidth="300" />
                </columns>
                <placeholder>
                    <Label text="Không có người dùng nào" style="-fx-text-fill: #95a5a6; -fx-font-size: 16px;"/>
                </placeholder>
            </TableView>
        </Tab>
    </TabPane>
</VBox>