<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import java.net.URL?>

<HBox fx:id="rootPane" prefHeight="750.0" prefWidth="1000.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.home.RegisterController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <VBox alignment="CENTER" prefWidth="400.0" spacing="30.0" style="-fx-background-color: #0A439D;" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="⚖" textFill="white">
                            <font><Font name="System Bold" size="80.0" /></font>
                        </Label>
                        <Label text="AUCTION SYSTEM" textFill="white">
                            <font><Font name="Segoe UI Black" size="32.0" /></font>
                        </Label>
                        <Separator maxWidth="150" opacity="0.3" />
                        <Label text="Hệ thống đấu giá trực tuyến" textFill="white">
                            <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        </Label>
                    </children>
                </VBox>
                <Label text="Tham gia cộng đồng đấu giá ngay để nhận những ưu đãi tốt nhất." textAlignment="CENTER" textFill="#b2c7e6" wrapText="true">
                    <font><Font name="Segoe UI Italic" size="14.0" /></font>
                    <VBox.margin><Insets left="40.0" right="40.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>

        <VBox prefWidth="600.0" HBox.hgrow="ALWAYS">

            <!-- NÚT GẠT ĐƯỢC CHÈN Ở GÓC TRÊN BÊN PHẢI -->
            <HBox alignment="TOP_RIGHT" style="-fx-padding: 20 20 0 0;">
                <HBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(127,140,141,0.2); -fx-padding: 6 15; -fx-background-radius: 20; -fx-cursor: hand;" onMouseClicked="#handleThemeToggle">
                    <SVGPath content="M 12 2 V 4 M 12 20 V 22 M 4 12 H 2 M 22 12 H 20 M 4.93 4.93 L 6.34 6.34 M 19.07 19.07 L 17.66 17.66 M 4.93 19.07 L 6.34 17.66 M 19.07 4.93 L 17.66 6.34 M 12 7 A 5 5 0 1 0 12 17 A 5 5 0 1 0 12 7 Z" stroke="#7f8c8d" strokeWidth="2" strokeLineCap="ROUND" fill="TRANSPARENT" scaleX="0.65" scaleY="0.65"/>
                    <StackPane>
                        <Rectangle fx:id="switchBackground" width="56" height="22" arcWidth="22" arcHeight="22" fill="#bdc3c7"/>
                        <Circle fx:id="switchKnob" radius="9" fill="white" translateX="-16"/>
                    </StackPane>
                    <SVGPath content="M 21 12.79 A 9 9 0 1 1 11.21 3 A 7 7 0 0 0 21 12.79 Z" fill="#7f8c8d" scaleX="0.65" scaleY="0.65"/>
                </HBox>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <padding><Insets bottom="30.0" left="40.0" right="40.0" top="10.0" /></padding>
                <children>
                    <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="500.0" spacing="12.0" styleClass="card">
                        <effect>
                            <DropShadow color="#0000001a" radius="15" spread="0.05" />
                        </effect>
                        <children>
                            <VBox spacing="5.0">
                                <children>
                                    <Label text="Tạo tài khoản mới" styleClass="section-title">
                                        <font><Font name="Segoe UI Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Bắt đầu hành trình đấu giá của bạn" styleClass="muted-text" />
                                </children>
                                <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                            </VBox>

                            <HBox spacing="15.0">
                                <children>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Họ và tên" styleClass="row-title-bold" />
                                        <TextField fx:id="txtFullName" prefHeight="40.0" promptText="Nhập họ và tên..." styleClass="modern-input" />
                                    </VBox>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Số điện thoại" styleClass="row-title-bold" />
                                        <TextField fx:id="txtPhoneNumber" prefHeight="40.0" promptText="Nhập số điện thoại..." styleClass="modern-input" />
                                    </VBox>
                                </children>
                            </HBox>

                            <HBox spacing="15.0">
                                <children>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Email" styleClass="row-title-bold" />
                                        <TextField fx:id="txtEmail" prefHeight="40.0" promptText="example@gmail.com" styleClass="modern-input" />
                                    </VBox>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Số CCCD" styleClass="row-title-bold" />
                                        <TextField fx:id="txtCitizenId" prefHeight="40.0" promptText="Nhập CCCD..." styleClass="modern-input" />
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="5.0">
                                <children>
                                    <Label text="Tên đăng nhập" styleClass="row-title-bold" />
                                    <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Chọn tên đăng nhập..." styleClass="modern-input" />
                                </children>
                            </VBox>

                            <HBox spacing="15.0">
                                <children>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="Mật khẩu" styleClass="row-title-bold" />
                                            <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="Mật khẩu" styleClass="modern-input" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="Xác nhận" styleClass="row-title-bold" />
                                            <PasswordField fx:id="txtConfirmPassword" prefHeight="40.0" promptText="Nhập lại" styleClass="modern-input" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <Button maxWidth="Infinity" onAction="#handleRegister" prefHeight="45.0" styleClass="btn-primary" style="-fx-font-size: 16px;" text="ĐĂNG KÝ NGAY">
                                <VBox.margin><Insets top="10.0" /></VBox.margin>
                            </Button>

                            <HBox alignment="CENTER" spacing="5.0">
                                <children>
                                    <Label text="Đã có tài khoản?" styleClass="row-title-bold" />
                                    <Hyperlink onAction="#goToLogin" style="-fx-text-fill: #3b5998; -fx-font-weight: bold;" text="Đăng nhập" />
                                </children>
                            </HBox>
                        </children>
                        <padding>
                            <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
                        </padding>
                    </VBox>
                </children>
            </StackPane>

        </VBox>
    </children>
</HBox>