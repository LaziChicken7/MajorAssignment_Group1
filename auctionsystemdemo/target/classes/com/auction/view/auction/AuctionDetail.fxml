<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.chart.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.auction.AuctionDetailController" style="-fx-background-color: transparent;">
    <children>

        <!-- LỚP 1: GIAO DIỆN CHÍNH -->
        <VBox spacing="15.0" style="-fx-background-color: transparent;">
            <children>

                <!-- HEADER: CỐ ĐỊNH Ở TRÊN CÙNG -->
                <HBox alignment="CENTER_LEFT">
                    <HBox spacing="5" styleClass="back-btn-container" onMouseClicked="#goBack" alignment="CENTER_LEFT">
                        <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
                        <Label text="Đấu giá" styleClass="back-title" />
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <!-- Nút biểu đồ trực tiếp -->
                    <HBox alignment="CENTER" spacing="15">
                        <Button text="Biểu đồ trực tiếp 📈" onAction="#handleOpenChart" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 20; -fx-padding: 6 20; -fx-cursor: hand;"/>

                        <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #3b5998; -fx-background-radius: 20; -fx-padding: 6 20;">
                            <Label text="Số dư:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                            <Label fx:id="lblBalance" text="****** VND" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                            <Label fx:id="eyeIconText" onMouseClicked="#toggleBalanceVisibility" text="Hiện"
                                   style="-fx-text-fill: #dcdde1; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0 0 0 5;"/>
                        </HBox>
                    </HBox>
                </HBox>

                <!-- VÙNG CUỘN TÀNG HÌNH -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background: transparent; -fx-background-color: transparent; -fx-padding: 0; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" style="-fx-padding: 5 5 20 5;">

                            <!-- KHUNG TRÊN: ẢNH VÀ THÔNG TIN -->
                            <HBox spacing="20.0" styleClass="card" style="-fx-padding: 15;">

                                <!-- Cột Ảnh -->
                                <VBox alignment="CENTER" spacing="10" prefWidth="300.0">
                                    <HBox alignment="CENTER" spacing="15">
                                        <Label fx:id="btnPrevImage" onMouseClicked="#prevImage" styleClass="slider-btn">
                                            <graphic><SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" /></graphic>
                                        </Label>
                                        <ImageView fx:id="productImageView" onMouseClicked="#handleOpenImageZoom" fitHeight="180.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true" style="-fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);">
                                            <image><Image url="https://via.placeholder.com/180?text=Loading..." /></image>
                                        </ImageView>
                                        <Label fx:id="btnNextImage" onMouseClicked="#nextImage" styleClass="slider-btn">
                                            <graphic><SVGPath content="M 6 4 L 16 14 L 6 24" styleClass="back-icon" /></graphic>
                                        </Label>
                                    </HBox>
                                    <Label fx:id="lblImageIndex" text="0/0" styleClass="muted-text" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                </VBox>

                                <Separator orientation="VERTICAL" style="-fx-opacity: 0.3;" />

                                <!-- Cột Thông tin -->
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS" alignment="CENTER">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label fx:id="lblId" text="SP1" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #7f8c8d;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblTime" text="00:00:00" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-padding: 4 12; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                                    </HBox>

                                    <Label fx:id="lblName" text="Tên sản phẩm" styleClass="section-title" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                                    <HBox alignment="CENTER" spacing="20">
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label text="Giá khởi điểm" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                                            <Label fx:id="lblStartPrice" text="0 VND" style="-fx-background-color: #3b5998; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                                        </VBox>
                                        <VBox alignment="CENTER" spacing="2">
                                            <Label text="Giá bạn đặt" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                                            <Label fx:id="lblMyBid" text="0 VND" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                                        </VBox>
                                    </HBox>

                                    <VBox alignment="CENTER" spacing="3">
                                        <Label fx:id="lblCurrentPrice" text="0 VND" alignment="CENTER" maxWidth="Infinity" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 25;"/>
                                        <HBox alignment="CENTER" spacing="5">
                                            <Label text="Người trả cao nhất:" styleClass="muted-text" style="-fx-font-size: 13px;"/>
                                            <Label fx:id="lblHighestBidder" text="Chưa có" styleClass="section-title" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                        </HBox>
                                    </VBox>

                                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 5 0 0 0;">
                                        <Button text="-" onAction="#decreaseBid" styleClass="btn-primary" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 12; -fx-background-radius: 20; -fx-background-color: #e74c3c;"/>
                                        <TextField fx:id="txtBidAmount" alignment="CENTER" promptText="Giá tiền..." prefWidth="130" styleClass="modern-input" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 20;"/>
                                        <Button text="+" onAction="#increaseBid" styleClass="btn-primary" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 12; -fx-background-radius: 20; -fx-background-color: #2ecc71;"/>
                                        <Button fx:id="btnBidAction" text="Thủ công" onAction="#handleBidClick" styleClass="btn-primary" style="-fx-font-size: 15px; -fx-padding: 8 15; -fx-background-radius: 20; -fx-margin-left: 5px;"/>
                                        <Button fx:id="btnAutoBidAction" text="Bot Đấu Giá" onAction="#handleOpenAutoBid" style="-fx-font-size: 15px; -fx-padding: 8 15; -fx-background-radius: 20; -fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                    </HBox>
                                </VBox>
                            </HBox>

                            <!-- KHUNG DƯỚI: CHIA TỶ LỆ 4:6 -->
                            <GridPane hgap="20">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="40" />
                                    <ColumnConstraints percentWidth="60" />
                                </columnConstraints>
                                <rowConstraints>
                                    <RowConstraints vgrow="ALWAYS" />
                                </rowConstraints>

                                <children>
                                    <!-- Ô 40%: Thuộc tính, Mô tả & THÔNG TIN NGƯỜI BÁN -->
                                    <VBox GridPane.columnIndex="0" spacing="15">

                                        <!-- Card 1: Kỹ thuật & Mô tả -->
                                        <VBox spacing="12" styleClass="card" style="-fx-padding: 15;">
                                            <VBox spacing="5">
                                                <Label text="Thông tin kỹ thuật:" styleClass="section-title" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                                                <!-- Đổi màu nền cứng thành class custom-row -->
                                                <VBox fx:id="vboxItemDetails" spacing="5" styleClass="custom-row" style="-fx-padding: 12;"/>
                                            </VBox>
                                            <Separator style="-fx-opacity: 0.3;" />
                                            <VBox spacing="5" VBox.vgrow="ALWAYS">
                                                <Label text="Mô tả chi tiết:" styleClass="section-title" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                                                <TextArea fx:id="txtDescription" editable="false" wrapText="true" prefHeight="100" styleClass="modern-text-area" style="-fx-font-size: 13px; -fx-background-color: transparent;" VBox.vgrow="ALWAYS"/>
                                            </VBox>
                                        </VBox>

                                        <!-- Card 2: Thông tin Người Bán -->
                                        <HBox spacing="15" styleClass="card" style="-fx-padding: 15; -fx-alignment: center-left;">
                                            <ImageView fx:id="imgSellerAvatar" fitWidth="45" fitHeight="45" />
                                            <VBox spacing="2" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                                                <Label text="Người bán" styleClass="muted-text" style="-fx-font-size: 12px;"/>
                                                <Label fx:id="lblSellerName" text="Đang tải..." styleClass="section-title" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                                                <Label fx:id="lblSellerRating" text="⭐ 0.0/5.0" style="-fx-text-fill: #e67e22; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                            </VBox>
                                            <Button text="Xem hồ sơ" onAction="#handleOpenSellerProfile" style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand;"/>
                                        </HBox>

                                    </VBox>

                                    <!-- Ô 60%: Thống kê & Lịch sử Đấu giá -->
                                    <VBox GridPane.columnIndex="1" spacing="15" styleClass="card" style="-fx-padding: 20;">
                                        <Label text="Thống kê &amp; Lịch sử đấu giá:" styleClass="section-title" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

                                        <!-- THANH PROGRESS BAR: Đổi màu nền cứng thành custom-row -->
                                        <VBox spacing="8" styleClass="custom-row" style="-fx-padding: 15;">
                                            <HBox alignment="CENTER_LEFT">
                                                <Label fx:id="lblHistoryName" text="Tên SP" styleClass="row-title-bold" style="-fx-font-size: 16px;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="lblHistoryCurrentPrice" text="+0 VND" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #e74c3c;"/>
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <Label fx:id="lblHistoryStartPrice" text="Từ: 0" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-min-width: 80px;"/>
                                                <ProgressBar fx:id="bidProgressBar" progress="0.0" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="red-progress-bar"/>
                                                <Label fx:id="lblHistoryPercent" text="+0%" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #e74c3c; -fx-min-width: 65px; -fx-alignment: center-right;"/>
                                            </HBox>
                                        </VBox>

                                        <!-- DANH SÁCH LỊCH SỬ GIAO DỊCH -->
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="Lịch sử giao dịch (5 lượt gần nhất):" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <!-- Nút Xem tất cả -->
                                            <Label text="Xem tất cả" onMouseClicked="#handleOpenHistory" style="-fx-background-color: #3b5998; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 5 15; -fx-background-radius: 20; -fx-cursor: hand;"/>
                                        </HBox>
                                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background-color: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                                            <content>
                                                <VBox fx:id="vboxBidHistory" spacing="8" style="-fx-padding: 5;"/>
                                            </content>
                                        </ScrollPane>
                                    </VBox>
                                </children>
                            </GridPane>

                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <!-- LỚP 3: POPUP XÁC NHẬN ĐẤU GIÁ THỦ CÔNG -->
        <VBox fx:id="paneConfirm" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.5);">
            <VBox alignment="CENTER" spacing="20" styleClass="card" style="-fx-max-width: 450; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20, 0, 0, 10);">
                <Label text="Xác nhận đấu giá" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Bạn muốn đặt cược với giá:" style="-fx-font-size: 15px;"/>
                <Label fx:id="lblConfirmAmount" text="0 VND" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                <HBox alignment="CENTER" spacing="20">
                    <Button text="Xác nhận" onAction="#processConfirmBid" prefWidth="130" styleClass="btn-success" style="-fx-font-size: 15px; -fx-padding: 10;"/>
                    <Button text="Hủy bỏ" onAction="#handleCancelPopup" prefWidth="130" styleClass="btn-danger" style="-fx-font-size: 15px; -fx-padding: 10;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- LỚP 4: POPUP PHÓNG TO ẢNH -->
        <VBox fx:id="paneImageZoom" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.85);" onMouseClicked="#handleCloseImageZoom">
            <StackPane maxWidth="750" maxHeight="550">
                <ImageView fx:id="zoomedImageView" fitWidth="700" fitHeight="500" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 20, 0, 0, 10);" />
                <Button text="✕" onAction="#handleCloseImageZoom" StackPane.alignment="TOP_RIGHT"
                        style="-fx-background-color: rgba(231, 76, 60, 0.8); -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 50; -fx-cursor: hand; -fx-padding: 2 10;">
                    <StackPane.margin>
                        <Insets top="-15" right="-15"/>
                    </StackPane.margin>
                </Button>
            </StackPane>
        </VBox>

        <!-- LỚP 5: POPUP CÀI ĐẶT BOT (AUTO-BID) -->
        <VBox fx:id="paneAutoBidConfig" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.5);">
            <VBox alignment="CENTER" spacing="15" styleClass="card" style="-fx-max-width: 450; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20, 0, 0, 10);">
                <Label text="🤖 Cài đặt Bot Đấu Giá" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>

                <!-- BỔ SUNG: KHỐI HIỂN THỊ TRẠNG THÁI VÀ MỨC TRẦN ĐANG CHẠY -->
                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="lblCurrentBotStatus" text="Trạng thái: Đang kiểm tra..." style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #95a5a6;"/>
                    <Label fx:id="lblCurrentMaxBid" text="Mức trần đang cài: 0 VND" visible="false" managed="false" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                </VBox>

                <Label text="Hệ thống sẽ tự động trả giá thay bạn đến khi đạt mức trần." textAlignment="CENTER" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

                <Label fx:id="lblAutoBidStep" text="Bước giá: Đang tính..." style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>

                <VBox spacing="5" alignment="CENTER">
                    <Label text="Mức giá tối đa bạn muốn điều chỉnh:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 5 0 0 0;">
                        <Button text="-" onAction="#decreaseAutoBid" styleClass="btn-primary" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 12; -fx-background-radius: 20; -fx-background-color: #e74c3c;"/>
                        <TextField fx:id="txtAutoBidMaxAmount" alignment="CENTER" promptText="Giá trần (VND)" prefWidth="180" styleClass="modern-input" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 20;"/>
                        <Button text="+" onAction="#increaseAutoBid" styleClass="btn-primary" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 12; -fx-background-radius: 20; -fx-background-color: #2ecc71;"/>
                    </HBox>
                </VBox>
                <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 0 0 0;">
                    <Button fx:id="btnSubmitAutoBid" text="Kích hoạt Bot" onAction="#processSetupAutoBid" prefWidth="150" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 10; -fx-background-radius: 25; -fx-cursor: hand;"/>
                    <Button text="Hủy bỏ" onAction="#handleCloseAutoBid" prefWidth="130" styleClass="btn-danger" style="-fx-font-size: 15px; -fx-padding: 10; -fx-background-radius: 25;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- LỚP 2: THÔNG BÁO TOAST -->
        <VBox alignment="TOP_CENTER" mouseTransparent="true">
            <padding><Insets top="15"/></padding>
            <children>
                <HBox fx:id="toastSuccess" visible="false" alignment="CENTER" spacing="10" maxWidth="400" style="-fx-background-color: #2ecc71; -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                    <Label text="✔" textFill="white" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Thao tác thành công!" textFill="white" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                </HBox>
                <HBox fx:id="toastError" visible="false" alignment="CENTER" spacing="10" maxWidth="650" style="-fx-background-color: #e74c3c; -fx-background-radius: 10; -fx-padding: 12 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                    <Label text="✕" textFill="white" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblToastErrorMsg" text="Lỗi hệ thống!" wrapText="true" textAlignment="CENTER" textFill="white" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                </HBox>
            </children>
        </VBox>

    </children>
</StackPane>