<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.addauctionitem.MyAuctionListController" spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="title-container">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label text="Sản phẩm của tôi" styleClass="back-title" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <!-- Nút Thêm và Làm mới -->
            <Button text="➕ Thêm sản phẩm" onAction="#goToAddProduct" styleClass="btn-success" style="-fx-font-size: 14px; -fx-padding: 8 20;"/>
            <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-primary" style="-fx-font-size: 14px; -fx-padding: 8 20;"/>

            <!-- Khung Số dư -->
            <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #3b5998; -fx-background-radius: 20; -fx-padding: 6 20;">
                <Label text="Số dư:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                <Label fx:id="lblBalance" text="****** VND" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                <Label fx:id="eyeIconText" onMouseClicked="#toggleBalanceVisibility" text="Hiện"
                       style="-fx-text-fill: #dcdde1; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0 0 0 5;"/>
            </HBox>
        </HBox>
    </HBox>

    <!-- BỌC LISTVIEW VÀ LOADING VÀO STACKPANE -->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- 1. Danh sách sản phẩm -->
        <ListView fx:id="myAuctionListView" styleClass="list-view" />

        <!-- 2. Vòng tròn Loading xoay xoay (Mặc định ẩn) -->
        <!-- Đã sửa màu nền thành transparent và xóa màu cứng của chữ -->
        <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="10"
              style="-fx-background-color: transparent;" visible="false">
            <ProgressIndicator prefWidth="50" prefHeight="50"/>
            <Label text="Đang tải dữ liệu..." style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>

    </StackPane>

</VBox>