<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.auction.AuctionHistoryController" style="-fx-background-color: transparent;">
    <children>

        <!-- LỚP 1: GIAO DIỆN CHÍNH -->
        <VBox spacing="15.0" style="-fx-background-color: transparent;">
            <children>

                <!-- HEADER ĐỒNG BỘ CÁC TRANG -->
                <HBox alignment="CENTER_LEFT" minHeight="36">
                    <HBox spacing="5" styleClass="back-btn-container" onMouseClicked="#goBack" alignment="CENTER_LEFT">
                        <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
                        <Label fx:id="lblTitle" text="Tất cả lịch sử giao dịch" styleClass="back-title" />
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- ĐÃ SỬA: Nút Làm mới theo đúng yêu cầu của bạn -->
                    <Button text="🔄 Làm mới" onAction="#refreshData" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <!-- BẢNG DỮ LIỆU & PHÂN TRANG -->
                <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 5 5 20 5;">
                    <VBox VBox.vgrow="ALWAYS" spacing="10" styleClass="card" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

                        <!-- TableView -->
                        <TableView fx:id="tableHistory" VBox.vgrow="ALWAYS" styleClass="modern-table" style="-fx-font-size: 14.5px;">
                            <columns>
                                <TableColumn fx:id="colStt" text="STT" prefWidth="60" style="-fx-alignment: CENTER; -fx-font-weight: bold; -fx-text-fill: #95a5a6;" />
                                <TableColumn fx:id="colTime" text="Thời gian" prefWidth="200" style="-fx-alignment: CENTER; -fx-text-fill: #7f8c8d;" />
                                <TableColumn fx:id="colUser" text="Người tham gia" prefWidth="250" style="-fx-alignment: CENTER-LEFT; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <TableColumn fx:id="colAmount" text="Mức giá (VND)" prefWidth="200" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #e67e22; -fx-font-size: 15px;" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <!-- Phân trang: Đã gắn thêm class modern-pagination -->
                        <Pagination fx:id="pagination" maxPageIndicatorCount="5" styleClass="modern-pagination"/>

                    </VBox>
                </VBox>

            </children>
        </VBox>

    </children>
</StackPane>