<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<!-- ĐÃ THÊM: cache="true" và cacheHint="SPEED" để JavaFX vẽ khối này thành ảnh tĩnh (bitmap) -->
<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.auction.AuctionItemController"
      spacing="20" alignment="CENTER_LEFT"
      styleClass="custom-row, auction-row-card" style="-fx-padding: 20; -fx-cursor: hand;"
      cache="true" cacheHint="SPEED">

    <!-- CỘT TRÁI: ẢNH SẢN PHẨM -->
    <VBox alignment="CENTER" minWidth="130" minHeight="130">
        <!-- ĐÃ THÊM: smooth="true", cache="true", cacheHint="SPEED" để tối ưu render ảnh -->
        <ImageView fx:id="imgThumbnail" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" smooth="true" cache="true" cacheHint="SPEED">
            <image>
                <Image url="https://via.placeholder.com/120?text=Loading..." />
            </image>
        </ImageView>
    </VBox>

    <!-- CỘT PHẢI: THÔNG TIN SẢN PHẨM -->
    <VBox spacing="15" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">

        <!-- Dòng 1: ID, Tên và Trạng thái -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label fx:id="lblId" text="SP1" styleClass="row-title-bold" style="-fx-font-size: 18px;"/>
            <Label fx:id="lblName" text="Auction Name" styleClass="row-text-normal" style="-fx-font-size: 18px;"/>

            <Region HBox.hgrow="ALWAYS" />

            <Label text="Trạng thái:" styleClass="muted-text" style="-fx-font-size: 15px;"/>
            <Label fx:id="lblStatus" text="Đang tải..." style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Dòng 2: Giá và Thời gian -->
        <HBox alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Giá hiện tại:" styleClass="muted-text" style="-fx-font-size: 15px;"/>
                <!-- Màu nền xanh đậm cho Giá tiền -->
                <Label fx:id="lblPrice" text="0 VND" style="-fx-background-color: #3b5998; -fx-text-fill: white; -fx-padding: 5 20; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 15px;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="lblTimeTitle" text="Thời gian còn lại:" styleClass="muted-text" style="-fx-font-size: 15px;"/>
                <Label fx:id="lblTime" text="00:00:00" style="-fx-padding: 5 20; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: white;"/>
            </HBox>
        </HBox>

    </VBox>
</HBox>