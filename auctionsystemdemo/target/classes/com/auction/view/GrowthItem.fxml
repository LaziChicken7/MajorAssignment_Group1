<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="5" styleClass="growth-row" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.GrowthItemController">
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label fx:id="lblName" text="User Name" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblAbsoluteGain" text="+0 VND" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <children>
                <Label fx:id="lblFromValue" text="Từ: 0" styleClass="text-muted" />
                <ProgressBar fx:id="pbGrowth" progress="0.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="10.0" styleClass="growth-progress" />
                <Label fx:id="lblPercentage" text="0%" minWidth="80" alignment="CENTER_RIGHT" />
            </children>
        </HBox>
    </children>
</VBox>