<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="20" style="-fx-background-color: transparent;">
    <Label text="&lt; Profile của tôi" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;"/>

    <HBox styleClass="card" spacing="40" alignment="CENTER_LEFT">
        <VBox alignment="CENTER" spacing="15">
            <!-- Vòng tròn Avatar -->
            <StackPane style="-fx-background-color: black; -fx-background-radius: 100;" prefWidth="200" prefHeight="200">
                <Label text="👤" style="-fx-font-size: 80px; -fx-text-fill: white;"/>
            </StackPane>
            <Button text="Tải ảnh lên" styleClass="btn-primary" />
        </VBox>

        <GridPane hgap="20" vgap="15" HBox.hgrow="ALWAYS">
            <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField text="pipodaucatmoi" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="400"/>

            <Label text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField text="Phan Văn Tuyển" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField text="pipodaucatmoi@gmail.com" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField text="0962970867" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="CCCD:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField text="040207001111" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="5">
                <Button text="Xác nhận chỉnh sửa" style="-fx-background-color: #B0B0B0; -fx-text-fill: white; -fx-background-radius: 15; -fx-padding: 8 20;" />
            </HBox>
        </GridPane>
    </HBox>
    <HBox alignment="CENTER">
        <Button text="Đăng xuất" styleClass="btn-danger" style="-fx-padding: 10 30;"/>
    </HBox>
</VBox>