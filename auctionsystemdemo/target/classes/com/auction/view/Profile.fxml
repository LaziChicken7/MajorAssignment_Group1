<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.ProfileController" spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT" spacing="5" styleClass="title-container">
        <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
        <Label text="Profile của tôi" styleClass="back-title" />
    </HBox>

    <HBox styleClass="card" spacing="40" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <VBox alignment="CENTER" spacing="15">
            <StackPane style="-fx-background-color: black; -fx-background-radius: 100;" prefWidth="200" prefHeight="200">
                <Label text="👤" style="-fx-font-size: 80px; -fx-text-fill: white;"/>
            </StackPane>
            <Button text="Tải ảnh lên" style="-fx-background-color: #0A439D; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 25; -fx-font-weight: bold; -fx-cursor: hand;" />
        </VBox>

        <GridPane hgap="20" vgap="15" HBox.hgrow="ALWAYS">
            <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField fx:id="txtUsername" editable="false" style="-fx-background-color: #f0f0f0; -fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="400"/>

            <Label text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField fx:id="txtFullName" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField fx:id="txtEmail" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField fx:id="txtPhone" editable="false" style="-fx-background-color: #f0f0f0; -fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="CCCD:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <TextField fx:id="txtCitizenId" editable="false" style="-fx-background-color: #f0f0f0; -fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Mật khẩu mới:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            <PasswordField fx:id="txtPassword" promptText="Bỏ trống nếu không muốn đổi mật khẩu" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 8;" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <Button text="Xác nhận chỉnh sửa" onAction="#handleUpdateProfile" style="-fx-background-color: #0A439D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 10 20; -fx-cursor: hand;" />
            </HBox>
        </GridPane>
    </HBox>

    <!-- HBox bọc 2 nút lại với nhau -->
    <HBox alignment="CENTER" spacing="20">
        <!-- Nút Trung tâm điều khiển (Mặc định ẩn) -->
        <Button fx:id="btnAdminControl" text="⚙ Trung tâm điều khiển" visible="false" managed="false" onAction="#handleOpenAdminControl" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 30; -fx-cursor: hand;"/>

        <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: #FF0000; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 30; -fx-cursor: hand;"/>
    </HBox>
</VBox>