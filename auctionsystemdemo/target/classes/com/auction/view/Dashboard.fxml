<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController"
      spacing="20" style="-fx-background-color: transparent;">

    <VBox spacing="15" styleClass="card">
        <HBox alignment="CENTER_LEFT">
            <Label text="Sản phẩm nổi bật" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Xem tất cả" onAction="#goToAuctionList" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20;"/>
        </HBox>

        <VBox fx:id="vboxFeaturedAuctions" spacing="10">
            <Label text="Đang tải dữ liệu..." style="-fx-text-fill: #888; -fx-font-style: italic;"/>
        </VBox>
    </VBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">

        <VBox HBox.hgrow="ALWAYS" spacing="15" prefWidth="400" styleClass="card">
            <HBox alignment="CENTER_LEFT">
                <Label text="Thông báo mới" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label fx:id="lblNotifCount" text="0" visible="false" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 6; -fx-translate-x: 5; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Chi tiết" onAction="#handleViewMoreNotifications" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 6 15;"/>
            </HBox>

            <VBox fx:id="vboxNotifications" spacing="15">
                <Label text="Đang tải dữ liệu..." style="-fx-text-fill: #888; -fx-font-style: italic;"/>
            </VBox>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" spacing="15" styleClass="card">
            <Label text="Thống kê Tăng trưởng (VND)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <LineChart createSymbols="true" VBox.vgrow="ALWAYS" fx:id="chartAuction">
                <xAxis><CategoryAxis label="Mã Sản phẩm" /></xAxis>
                <yAxis><NumberAxis label="Giá (VND)" /></yAxis>
            </LineChart>
        </VBox>

    </HBox>

</VBox>