<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">
    <content>
        <VBox spacing="20" style="-fx-background-color: transparent; -fx-padding: 0 10 10 0;">

            <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Sản phẩm nổi bật" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Xem tất cả" onAction="#goToAuctionList" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20;"/>
                </HBox>

                <VBox fx:id="vboxFeaturedAuctions" spacing="10">
                    <Label text="Đang tải dữ liệu..." style="-fx-text-fill: #888; -fx-font-style: italic;"/>
                </VBox>
            </VBox>

            <HBox spacing="25" VBox.vgrow="ALWAYS">

                <VBox HBox.hgrow="SOMETIMES" spacing="15" minWidth="250" prefWidth="350" styleClass="card">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Thông báo mới" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label fx:id="lblNotifCount" text="0" visible="false" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 6; -fx-translate-x: 5; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Chi tiết" onAction="#handleViewMoreNotifications" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 6 15;"/>
                    </HBox>

                    <VBox fx:id="vboxNotifications" spacing="15">
                        <Label text="Đang tải dữ liệu..." style="-fx-text-fill: #888; -fx-font-style: italic;"/>
                    </VBox>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="15" minWidth="300" styleClass="card">
                    <Label text="Thống kê Tăng trưởng (Top 4)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

                    <VBox fx:id="vboxStatistics" spacing="12" VBox.vgrow="ALWAYS">
                        <Label text="Đang tải dữ liệu..." style="-fx-text-fill: #888; -fx-font-style: italic;"/>
                    </VBox>
                </VBox>

            </HBox>
        </VBox>
    </content>
</ScrollPane>