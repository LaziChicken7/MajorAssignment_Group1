<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.LoginController">
    <children>
        <!-- BÊN TRÁI: PANEL THƯƠNG HIỆU -->
        <VBox alignment="CENTER" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #0A439D;">
            <children>
                <Label text="Hệ thống đấu giá trực tuyến" textFill="white">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
                <Label text="Minh bạch - An toàn - Hiệu quả" textFill="white" />
            </children>
        </VBox>

        <!-- BÊN PHẢI: FORM ĐĂNG NHẬP -->
        <VBox alignment="CENTER" prefWidth="500.0" spacing="25.0" style="-fx-background-color: white;">
            <padding><Insets left="50.0" right="50.0" /></padding>
            <children>
                <Label text="Chào mừng quay trở lại!">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>

                <!-- TRƯỜNG NHẬP IP SERVER VÀ NÚT ÁP DỤNG -->
                <VBox spacing="5.0">
                    <children>
                        <Label text="Địa chỉ Server (IP/Domain)" textFill="#555555"/>
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="txtServerIp" prefHeight="40.0" promptText="VD: http://192.168.1.10:8080/auction" style="-fx-background-radius: 10;" HBox.hgrow="ALWAYS" />
                                <Button onAction="#handleApplyIp" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="Áp dụng" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Tên đăng nhập" />
                        <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Nhập tên đăng nhập..." style="-fx-background-radius: 10;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Mật khẩu" />
                        <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="Nhập mật khẩu..." style="-fx-background-radius: 10;" />
                    </children>
                </VBox>

                <Button maxWidth="Infinity" onAction="#handleLogin" prefHeight="45.0" style="-fx-background-color: #0A439D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="ĐĂNG NHẬP" />

                <HBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Chưa có tài khoản?" />
                        <Hyperlink text="Đăng ký ngay" style="-fx-text-fill: #0A439D;" onAction="#goToRegister" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>