<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.MyAuctionListController">
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Sản phẩm đấu giá của tôi" style="-fx-font-size: 20; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />

        <!-- NÚT THÊM SẢN PHẨM NẰM Ở ĐÂY -->
        <Button onAction="#goToAddProduct" text="Thêm sản phẩm"
                style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;"/>
    </HBox>

    <ListView fx:id="myAuctionListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;" />
</VBox>