<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Đã bỏ prefHeight, prefWidth và -fx-padding cứng để nó co giãn theo vùng Content giống Wallet -->
<VBox spacing="20" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.NotificationController">

    <!-- HEADER: Đã nhóm nút làm mới vào HBox con, xài style nút bấm quy chuẩn -->
    <HBox alignment="CENTER_LEFT">
        <Label text="&lt; Thông báo" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333333; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14px;"/>
        </HBox>
    </HBox>

    <!-- DANH SÁCH THÔNG BÁO -->
    <ListView fx:id="lvNotifications" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />

</VBox>