<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController" prefWidth="800.0" prefHeight="600.0">
    <!-- Thanh Header giữ nguyên -->
    <top>
        <HBox spacing="20" style="-fx-background-color: #f0f0f0;" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Label text="Trang Chủ Đấu Giá" style="-fx-font-size: 18px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" text="Xin chào, User!" />
            <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: #d9534f; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- Phần Center thay bằng TableView -->
    <center>
        <VBox spacing="10" alignment="TOP_CENTER">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="DANH SÁCH PHIÊN ĐẤU GIÁ HIỆN TẠI" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="Mã SP" prefWidth="80"/>
                    <TableColumn fx:id="colName" text="Tên sản phẩm" prefWidth="250"/>
                    <TableColumn fx:id="colPrice" text="Giá hiện tại ($)" prefWidth="120"/>
                    <TableColumn fx:id="colEndTime" text="Thời gian kết thúc" prefWidth="150"/>
                    <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>