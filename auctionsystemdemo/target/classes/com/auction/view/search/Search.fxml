<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.search.SearchController" spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="back-btn-container" onMouseClicked="#handleGoBack" style="-fx-cursor: hand;">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label styleClass="back-title" text="Kết quả tìm kiếm" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #e8f0fe; -fx-padding: 8 18; -fx-background-radius: 20;">
            <Label text="Từ khóa:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 15px;"/>
            <Label fx:id="lblKeyword" text="'từ khóa'" style="-fx-font-weight: bold; -fx-text-fill: #0A439D; -fx-font-size: 16px;"/>
        </HBox>
    </HBox>

    <TabPane styleClass="tab-pane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <Tab text="Sản phẩm đấu giá">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane-table" style="-fx-background-color: transparent;">
                <content>
                    <FlowPane fx:id="paneItems" hgap="25" vgap="25" style="-fx-padding: 20;" alignment="TOP_LEFT"/>
                </content>
            </ScrollPane>
        </Tab>

        <Tab text="Người dùng">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="scroll-pane-table" style="-fx-background-color: transparent;">
                <content>
                    <VBox fx:id="paneUsers" spacing="15" style="-fx-padding: 20;"/>
                </content>
            </ScrollPane>
        </Tab>

    </TabPane>
</VBox>