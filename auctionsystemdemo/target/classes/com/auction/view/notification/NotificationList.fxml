<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<StackPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.notification.NotificationController">

    <!-- LỚP DƯỚI: DANH SÁCH THÔNG BÁO -->
    <VBox spacing="20">
        <HBox alignment="CENTER_LEFT">
            <HBox spacing="5" styleClass="title-container" alignment="CENTER_LEFT">
                <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
                <Label text="Thông báo" styleClass="back-title" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_LEFT">
                <!-- THÊM NÚT XÓA TẤT CẢ TẠI ĐÂY -->
                <Button text="🗑 Xóa tất cả" onAction="#handleDeleteAll" styleClass="btn-pill-delete"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20; -fx-padding: 5 15; -fx-cursor: hand;"/>

                <!-- Dùng class có sẵn btn-pill-refresh -->
                <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-pill-refresh" style="-fx-font-size: 14px; -fx-padding: 5 15;"/>
            </HBox>
        </HBox>

        <!-- Thêm styleClass "notif-list-view" để CSS có thể nắm đầu nó -->
        <ListView fx:id="lvNotifications" styleClass="notif-list-view" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- LỚP TRÊN: POPUP HIỂN THỊ CHI TIẾT (MẶC ĐỊNH ẨN) -->
    <StackPane fx:id="popupOverlay" visible="false" styleClass="popup-overlay">

        <!-- KHUNG CHỨA NỘI DUNG (Dùng class popup-card) -->
        <VBox alignment="CENTER" spacing="20" styleClass="popup-card" maxWidth="700" maxHeight="350">
            <padding>
                <Insets top="40" right="40" bottom="30" left="40"/>
            </padding>

            <Label fx:id="lblPopupTitle" text="Tiêu đề" styleClass="notif-title" alignment="CENTER" maxWidth="Infinity"/>
            <Label fx:id="lblPopupDesc" text="Nội dung thông báo chi tiết..." styleClass="notif-message" wrapText="true" alignment="CENTER" maxWidth="Infinity"/>
            <Label fx:id="lblPopupTime" text="Thời gian" styleClass="notif-time" alignment="CENTER" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS" />

            <!-- KHU VỰC CÁC NÚT BẤM -->
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="btnPopupAccept" text="✔ Xác nhận" onAction="#handlePopupAccept" styleClass="notif-btn-accept" />
                <Button fx:id="btnPopupDecline" text="✖ Từ chối" onAction="#handlePopupDecline" styleClass="notif-btn-reject" />
                <Button fx:id="btnPopupDelete" text="🗑 Xóa thông báo" onAction="#handlePopupDelete" styleClass="notif-btn-delete" />
                <Button fx:id="btnPopupClose" text="Đóng lại" onAction="#closePopup" styleClass="notif-btn-close" />
            </HBox>
        </VBox>
    </StackPane>
</StackPane>