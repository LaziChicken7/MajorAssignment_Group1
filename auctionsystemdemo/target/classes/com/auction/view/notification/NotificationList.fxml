<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<!-- Dùng StackPane làm Root để chứa cả Danh sách và Lớp Popup đè lên trên -->
<StackPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.notification.NotificationController">

    <!-- LỚP DƯỚI: DANH SÁCH THÔNG BÁO -->
    <VBox spacing="20">
        <HBox alignment="CENTER_LEFT">
            <!-- ĐÃ THAY BẰNG SVGPATCH THEO Ý BẠN -->
            <HBox spacing="5" styleClass="title-container" alignment="CENTER_LEFT">
                <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
                <Label text="Thông báo" styleClass="back-title" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14px;"/>
            </HBox>
        </HBox>

        <ListView fx:id="lvNotifications" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />
    </VBox>

    <!-- LỚP TRÊN: POPUP HIỂN THỊ CHI TIẾT (MẶC ĐỊNH ẨN) -->
    <StackPane fx:id="popupOverlay" visible="false" style="-fx-background-color: rgba(0, 0, 0, 0.5);">

        <!-- KHUNG TRẮNG CHỨA NỘI DUNG -->
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10);" maxWidth="700" maxHeight="350">
            <padding>
                <Insets top="40" right="40" bottom="30" left="40"/>
            </padding>

            <Label fx:id="lblPopupTitle" text="Tiêu đề" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333333;" alignment="CENTER" maxWidth="Infinity"/>

            <Label fx:id="lblPopupDesc" text="Nội dung thông báo chi tiết..." style="-fx-font-size: 16px; -fx-text-fill: #555555;" wrapText="true" alignment="CENTER" maxWidth="Infinity"/>

            <Label fx:id="lblPopupTime" text="Thời gian" style="-fx-font-size: 14px; -fx-text-fill: #999999;" alignment="CENTER" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS" />

            <!-- KHU VỰC CÁC NÚT BẤM -->
            <HBox spacing="20" alignment="CENTER">
                <!-- Nút Đồng ý / Từ chối (Chỉ hiện khi là thông báo Xác thực) -->
                <Button fx:id="btnPopupAccept" text="✔ Xác nhận" onAction="#handlePopupAccept" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 30; -fx-cursor: hand;" />
                <Button fx:id="btnPopupDecline" text="✖ Từ chối" onAction="#handlePopupDecline" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 30; -fx-cursor: hand;" />

                <!-- Nút Xóa (Chỉ hiện khi là thông báo thường) -->
                <Button fx:id="btnPopupDelete" text="🗑 Xóa thông báo" onAction="#handlePopupDelete" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 30; -fx-cursor: hand;" />

                <!-- Nút Đóng (Lúc nào cũng hiện) -->
                <Button fx:id="btnPopupClose" text="Đóng lại" onAction="#closePopup" style="-fx-background-color: #0A56D2; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 40; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </StackPane>
</StackPane>