<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 5);" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.StartAuctionController">

    <Label text="Cài đặt phiên đấu giá" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #004aad;"/>
    <Separator/>

    <!-- Hiện thông tin sản phẩm để người dùng biết họ đang set cho cái nào -->
    <VBox spacing="5">
        <Label text="Sản phẩm đang chọn:" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        <Label fx:id="lblSelectedProduct" text="[SP000] - Tên sản phẩm" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
    </VBox>

    <VBox spacing="20">
        <VBox spacing="5">
            <Label text="Số tiền ban đầu (VND):" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
            <TextField fx:id="txtStartPrice" promptText="VD: 1000000" style="-fx-padding: 10; -fx-background-radius: 5; -fx-font-size: 14px;" />
        </VBox>

        <HBox spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Ngày kết thúc:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                <DatePicker fx:id="dpEnd" style="-fx-padding: 5;" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Giờ kết thúc:" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                <TextField fx:id="txtEndTime" prefWidth="120" promptText="VD: 23:59" style="-fx-padding: 10; -fx-background-radius: 5; -fx-font-size: 14px;" />
            </VBox>
        </HBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-padding: 10 0 0 0;">
        <Button text="Hủy bỏ" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20;"/>
        <Button text="🚀 Bắt đầu Đấu giá" onAction="#handleStartAuctionSubmit" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-padding: 10 30; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;" />
    </HBox>

</VBox>