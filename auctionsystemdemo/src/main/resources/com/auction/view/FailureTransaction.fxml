<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.TransactionController"
      spacing="20"
      style="-fx-background-color: transparent; -fx-padding: 25;">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="&lt; Giao dịch không thành công"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333333; -fx-cursor: hand;"
               onMouseClicked="#handleBackToWallet" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: transparent; -fx-background-color: transparent;"
                VBox.vgrow="ALWAYS">
        <content>
            <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 5); -fx-padding: 30;">

                <!-- Bác sĩ JavaFX sẽ "bơm" dữ liệu thật vào cái hộp này -->
                <VBox fx:id="failedContainer" spacing="20" />

            </VBox>
        </content>
    </ScrollPane>
</VBox>