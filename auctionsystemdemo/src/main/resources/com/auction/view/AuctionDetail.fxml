<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<StackPane prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionDetailController">
    <children>

        <!-- LỚP 1: GIAO DIỆN CHÍNH -->
        <VBox spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-padding: 20;">
            <children>
                <!-- Header quay lại -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button text=" Quay lại" onAction="#goBack" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Số dư: 144.250.000 VND" style="-fx-text-fill: #004aad; -fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Ảnh sản phẩm -->
                        <VBox alignment="TOP_CENTER" spacing="10">
                            <ImageView fitHeight="280.0" fitWidth="350.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="https://via.placeholder.com/350x280" />
                                </image>
                            </ImageView>
                            <Label text="1/10"/>
                        </VBox>

                        <!-- Thông tin chi tiết bên phải -->
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15;">
                            <children>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label fx:id="lblId" text="SP1" style="-fx-font-weight: bold; -fx-font-size: 18;"/>
                                    <Label fx:id="lblName" text="Tên sản phẩm" style="-fx-font-size: 18;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTime" text="00:01:12" style="-fx-background-color: #ffbd59; -fx-padding: 5 15; -fx-background-radius: 10; -fx-font-weight: bold;"/>
                                </HBox>

                                <GridPane vgap="10" hgap="20">
                                    <Label text="Giá ban đầu:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                    <Label fx:id="lblStartPrice" text="1.000.000 VND" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-padding: 3 15; -fx-background-radius: 10;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                    <Label text="Giá bạn đấu giá hiện tại:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                                    <Label fx:id="lblMyBid" text="0 VND" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 3 15; -fx-background-radius: 10;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                </GridPane>

                                <Label text="Giá hiện tại:" style="-fx-font-weight: bold;"/>
                                <Label fx:id="lblCurrentPrice" text="1.273.000 VND" maxWidth="Infinity" alignment="CENTER" style="-fx-background-color: #ff7e33; -fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 20;"/>

                                <HBox spacing="15" alignment="CENTER">
                                    <Label text="+" style="-fx-font-size: 20;"/>
                                    <TextField fx:id="txtBidAmount" promptText="Nhập giá tiền..." prefWidth="250" style="-fx-background-radius: 10; -fx-padding: 8;"/>
                                    <Button text="Đấu giá" onAction="#handleBidClick" style="-fx-background-color: #004aad; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 10; -fx-cursor: hand;"/>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Mô tả sản phẩm -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15;">
                    <Label text="Mô tả sản phẩm" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                    <TextArea fx:id="txtDescription" wrapText="true" editable="false" prefHeight="150" style="-fx-background-color: transparent;"/>
                </VBox>
            </children>
        </VBox>

        <!-- LỚP 2: THÔNG BÁO TOAST (Giữ nguyên của bạn) -->
        <VBox alignment="TOP_CENTER" mouseTransparent="true">
            <padding><Insets top="10"/></padding>
            <children>
                <HBox fx:id="toastSuccess" visible="false" alignment="CENTER" spacing="10" maxWidth="400" style="-fx-background-color: #2ecc71; -fx-background-radius: 15; -fx-padding: 12;">
                    <Label text="✔ Đấu giá thành công" textFill="white" style="-fx-font-weight: bold;"/>
                </HBox>
                <HBox fx:id="toastError" visible="false" alignment="CENTER" spacing="10" maxWidth="400" style="-fx-background-color: #ff3b30; -fx-background-radius: 15; -fx-padding: 12;">
                    <Label text="✘ Có người đấu giá tối ưu hơn" textFill="white" style="-fx-font-weight: bold;"/>
                </HBox>
            </children>
        </VBox>

        <!-- LỚP 3: POPUP XÁC NHẬN (Giữ nguyên của bạn) -->
        <VBox fx:id="paneConfirm" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.5);">
            <VBox alignment="CENTER" spacing="25" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 20; -fx-max-width: 500;">
                <Label text="Xác nhận đấu giá" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                <Label text="Bạn muốn đấu giá sản phẩm này với giá:"/>
                <Label fx:id="lblConfirmAmount" text="0 VND" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <HBox alignment="CENTER" spacing="30">
                    <Button text="Xác nhận" onAction="#processConfirmBid" prefWidth="150" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10; -fx-font-weight: bold;"/>
                    <Button text="Hủy bỏ" onAction="#handleCancelPopup" prefWidth="150" style="-fx-background-color: #ff3b30; -fx-text-fill: white; -fx-background-radius: 25; -fx-padding: 10; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>

    </children>
</StackPane>