<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.search.SearchController" spacing="20" style="-fx-background-color: transparent;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" minHeight="36">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="🔍" style="-fx-font-size: 24px;"/>
            <Label text="Kết quả tìm kiếm cho:" style="-fx-font-size: 20px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="lblKeyword" text="'từ khóa'" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0A439D;"/>
        </HBox>
    </HBox>

    <!-- KẾT QUẢ: 2 TAB -->
    <TabPane styleClass="tab-pane-custom" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

        <!-- TAB SẢN PHẨM -->
        <Tab text="Sản phẩm đấu giá">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background-color: transparent;">
                <content>
                    <!-- FlowPane giúp các thẻ sản phẩm tự rớt dòng tạo thành dạng lưới (Grid) -->
                    <FlowPane fx:id="paneItems" hgap="20" vgap="20" style="-fx-padding: 20;"/>
                </content>
            </ScrollPane>
        </Tab>

        <!-- TAB MỌI NGƯỜI (BẠN BÈ) -->
        <Tab text="Mọi người">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="edge-to-edge" style="-fx-background-color: transparent;">
                <content>
                    <VBox fx:id="paneUsers" spacing="10" style="-fx-padding: 20;"/>
                </content>
            </ScrollPane>
        </Tab>

    </TabPane>
</VBox>