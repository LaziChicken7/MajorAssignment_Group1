<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>
<?import java.net.URL?>

<HBox prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #f4f7f9;" styleClass="root-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.LoginController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <children>
        <VBox alignment="CENTER" prefWidth="450.0" spacing="30.0" style="-fx-background-color: #244fa1;" styleClass="sidebar" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="⚖" textFill="white" style="-fx-font-size: 80;">
                            <font><Font name="System Bold" size="80.0" /></font>
                        </Label>
                        <Label text="AUCTION SYSTEM" textFill="white" style="-fx-letter-spacing: 5;">
                            <font><Font name="Segoe UI Black" size="32.0" /></font>
                        </Label>
                        <Separator maxWidth="150" opacity="0.3" />
                        <Label text="Hệ thống đấu giá trực tuyến" textFill="white">
                            <font><Font name="Segoe UI Semibold" size="18.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Minh bạch - An toàn - Hiệu quả" textFill="#b2c7e6">
                            <font><Font name="Segoe UI Italic" size="14.0" /></font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </VBox>

        <StackPane prefWidth="500.0" HBox.hgrow="ALWAYS">
            <padding><Insets left="40.0" right="40.0" /></padding>
            <children>
                <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="450.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15;" styleClass="card">
                    <effect>
                        <DropShadow color="#0000001a" radius="15" spread="0.05" />
                    </effect>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Chào mừng quay trở lại!">
                                    <font><Font name="Segoe UI Bold" size="26.0" /></font>
                                </Label>
                                <Label text="Vui lòng đăng nhập để tiếp tục" textFill="#7f8c8d" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Địa chỉ Server (IP/Domain)" style="-fx-font-weight: bold; -fx-text-fill: #555555;" />
                                <HBox spacing="10.0">
                                    <TextField fx:id="txtServerIp" prefHeight="45.0" promptText="VD: http://192.168.1.x:8080/auction" styleClass="input-field" HBox.hgrow="ALWAYS" />
                                    <Button onAction="#handleApplyIp" prefHeight="45.0" prefWidth="90.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Áp dụng" />
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Tên đăng nhập" style="-fx-font-weight: bold;" />
                                <TextField fx:id="txtUsername" prefHeight="45.0" promptText="Nhập tên đăng nhập..." styleClass="input-field" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Mật khẩu" style="-fx-font-weight: bold;" />
                                <PasswordField fx:id="txtPassword" prefHeight="45.0" promptText="Nhập mật khẩu..." styleClass="input-field" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Hyperlink style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;" text="Quên mật khẩu?" />
                        </HBox>

                        <Button fx:id="btnLogin" maxWidth="Infinity" onAction="#handleLogin" prefHeight="50.0" style="-fx-background-color: #0b439e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" styleClass="btn-primary" text="ĐĂNG NHẬP" />

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Chưa có tài khoản?" />
                                <Hyperlink onAction="#goToRegister" style="-fx-text-fill: #0b439e; -fx-font-weight: bold;" text="Đăng ký ngay" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="40.0" left="35.0" right="35.0" top="40.0" />
                    </padding>
                </VBox>
            </children>
        </StackPane>
    </children>
</HBox>