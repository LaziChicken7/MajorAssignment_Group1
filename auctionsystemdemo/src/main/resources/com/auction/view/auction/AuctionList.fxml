<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.auction.AuctionController" spacing="20" style="-fx-background-color: transparent;">

    <!-- HEADER ĐÃ CHUẨN HÓA GIAO DIỆN ẨN/HIỆN TIỀN -->
    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="title-container">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label text="Đấu giá" styleClass="back-title" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14px; -fx-cursor: hand;"/>

            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #3b5998; -fx-background-radius: 20; -fx-padding: 6 20;">
                <Label text="Số dư:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                <Label fx:id="lblBalance" text="****** VND" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                <Label fx:id="eyeIconText" onMouseClicked="#toggleBalanceVisibility" text="Hiện"
                       style="-fx-text-fill: #dcdde1; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-underline: true;"/>
            </HBox>
        </HBox>
    </HBox>

    <!-- BỘ LỌC VÀ SẮP XẾP -->
    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="card" style="-fx-padding: 10 20;">

        <Label text="Lọc trạng thái:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <ComboBox fx:id="cbFilter" prefWidth="200" styleClass="modern-combo-box" style="-fx-cursor: hand;"/>

        <Region HBox.hgrow="ALWAYS" />

        <Label text="Sắp xếp thời gian:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
        <ComboBox fx:id="cbSort" prefWidth="240" styleClass="modern-combo-box" style="-fx-cursor: hand;"/>

    </HBox>

    <!-- ========================================================================= -->
    <!-- ĐÃ FIX: STACKPANE CHỨA LISTVIEW VÀ VÒNG XOAY LOADING (fx:id="loadingOverlay") -->
    <!-- ========================================================================= -->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- ĐÃ XÓA visible="false" ĐỂ NÓ LUÔN HIỂN THỊ -->
        <ListView fx:id="auctionListView" style="-fx-background-color: transparent; -fx-border-color: transparent;"/>

        <!-- Vòng xoay Loading -->
        <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="20" style="-fx-background-color: transparent;" visible="false">
            <ProgressIndicator prefWidth="50" prefHeight="50" style="-fx-progress-color: #3498db;" />
            <Label text="Đang tải dữ liệu, vui lòng chờ..." style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
        </VBox>

    </StackPane>

</VBox>