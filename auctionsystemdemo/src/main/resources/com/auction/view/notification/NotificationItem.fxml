<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Đổi nền thành đen -->
<HBox alignment="CENTER_LEFT" spacing="15" styleClass="notif-item-card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.notification.NotificationItemController">

    <VBox HBox.hgrow="ALWAYS" spacing="5">
        <!-- Đổi chữ thành trắng -->
        <Label fx:id="lblTitle" text="Tiêu đề thông báo" styleClass="notif-title"/>
        <Label fx:id="lblDescription" text="Nội dung chi tiết..." wrapText="true" styleClass="notif-message"/>
        <Label fx:id="lblTime" text="Thời gian" styleClass="notif-time"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnAccept" text="✔ Xác nhận" onAction="#handleAccept" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button fx:id="btnDecline" text="✖ Từ chối" onAction="#handleDecline" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button fx:id="btnDelete" text="🗑 Xóa" onAction="#handleDelete" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
    </HBox>
</HBox>