<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>
<?import java.net.URL?>

<?import javafx.scene.Group?>
<HBox fx:id="rootPane" prefHeight="750.0" prefWidth="1050.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.home.RegisterController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <!-- PANEL TRÁI: DẢI MÀU GRADIENT VÀ LOGO SVG -->
        <VBox alignment="CENTER" prefWidth="400.0" spacing="45.0" style="-fx-background-color: linear-gradient(to bottom right, #0A439D, #1A56B8, #051A3B);" HBox.hgrow="ALWAYS">
            <children>
                <VBox alignment="CENTER" spacing="20.0">
                    <children>
                        <!-- KHỐI LOGO BÚA ĐẤU GIÁ (GAVEL) ĐÃ ĐƯỢC VẼ LẠI CHUẨN XÁC -->
                        <StackPane>
                            <!-- Các vòng tròn phát sáng (Đã căn chỉnh lại cho cân đối với búa) -->
                            <Circle radius="85" fill="#ffffff" opacity="0.04"/>
                            <Circle radius="65" fill="#ffffff" opacity="0.08"/>
                            <Circle radius="45" fill="#ffffff" opacity="0.15"/>

                            <!-- Búa & Đế: Thuần trắng, căn giữa tuyệt đối -->
                            <Group scaleX="0.75" scaleY="0.75">
                                <!-- ĐẾ GÕ (SOUND BLOCK) -->
                                <Group translateY="45">
                                    <!-- Vòm khối gỗ -->
                                    <Rectangle x="-35" y="-12" width="70" height="24" arcWidth="24" arcHeight="24" fill="white"/>
                                    <!-- Tấm lót ngang -->
                                    <Rectangle x="-55" y="2" width="110" height="10" arcWidth="4" arcHeight="4" fill="white"/>
                                </Group>

                                <!-- BÚA (HAMMER) - Góc 45 độ, cán vát đúng chiều, đầu đập khóa chặt tâm đế -->
                                <Group rotate="45" translateX="12" translateY="-20">
                                    <!-- Nắp đập trên (Trái) -->
                                    <Rectangle x="-22" y="-40" width="44" height="12" arcWidth="6" arcHeight="6" fill="white"/>
                                    <!-- Thân búa -->
                                    <Rectangle x="-17" y="-28" width="34" height="56" fill="white"/>
                                    <!-- Nắp đập dưới (Phải - Chạm đế) -->
                                    <Rectangle x="-22" y="28" width="44" height="12" arcWidth="6" arcHeight="6" fill="white"/>
                                    <!-- Cán búa -->
                                    <Rectangle x="17" y="-8" width="85" height="16" arcWidth="8" arcHeight="8" fill="white"/>
                                </Group>
                            </Group>
                        </StackPane>

                        <VBox alignment="CENTER" spacing="8">
                            <VBox.margin><Insets top="20"/></VBox.margin>
                            <Label text="AUCTION SYSTEM" textFill="white" style="-fx-letter-spacing: 4;">
                                <font><Font name="Segoe UI Black" size="34.0" /></font>
                            </Label>
                            <Separator maxWidth="100" style="-fx-opacity: 0.4;" />
                            <Label text="Hệ thống Đấu giá Toàn diện" textFill="#e2e8f0">
                                <font><Font name="Segoe UI Semibold" size="16.0" /></font>
                            </Label>
                        </VBox>
                    </children>
                </VBox>
                <Label text="Tham gia cộng đồng đấu giá ngay để trải nghiệm cơ hội mua sắm đỉnh cao và an toàn tuyệt đối." textAlignment="CENTER" textFill="#93c5fd" wrapText="true" style="-fx-line-spacing: 7;">
                    <font><Font name="Segoe UI Italic" size="14.0" /></font>
                    <VBox.margin><Insets left="40.0" right="40.0" /></VBox.margin>
                </Label>
            </children>
        </VBox>

        <!-- PANEL PHẢI: FORM ĐĂNG KÝ -->
        <VBox prefWidth="650.0" HBox.hgrow="ALWAYS">

            <!-- NÚT GẠT THEME DARK/LIGHT -->
            <HBox alignment="TOP_RIGHT" style="-fx-padding: 20 20 0 0;">
                <HBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(127,140,141,0.15); -fx-padding: 6 15; -fx-background-radius: 20; -fx-cursor: hand;" onMouseClicked="#handleThemeToggle">
                    <SVGPath content="M 12 2 V 4 M 12 20 V 22 M 4 12 H 2 M 22 12 H 20 M 4.93 4.93 L 6.34 6.34 M 19.07 19.07 L 17.66 17.66 M 4.93 19.07 L 6.34 17.66 M 19.07 4.93 L 17.66 6.34 M 12 7 A 5 5 0 1 0 12 17 A 5 5 0 1 0 12 7 Z" stroke="#7f8c8d" strokeWidth="2" strokeLineCap="ROUND" fill="TRANSPARENT" scaleX="0.65" scaleY="0.65"/>
                    <StackPane>
                        <Rectangle fx:id="switchBackground" width="56" height="22" arcWidth="22" arcHeight="22" fill="#bdc3c7"/>
                        <Circle fx:id="switchKnob" radius="9" fill="white" translateX="-16"/>
                    </StackPane>
                    <SVGPath content="M 21 12.79 A 9 9 0 1 1 11.21 3 A 7 7 0 0 0 21 12.79 Z" fill="#7f8c8d" scaleX="0.65" scaleY="0.65"/>
                </HBox>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <padding><Insets bottom="20.0" left="50.0" right="50.0" top="10.0" /></padding>
                <children>
                    <!-- TĂNG SPACING TỪ 15 LÊN 24 ĐỂ CÁC HÀNG CÁCH XA NHAU HƠN -->
                    <VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="550.0" spacing="24.0" styleClass="card" style="-fx-background-radius: 20; -fx-padding: 45 45 50 45;">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.08)" radius="20" spread="0.01" offsetY="5" />
                        </effect>
                        <children>
                            <VBox spacing="8.0">
                                <children>
                                    <Label text="Tạo tài khoản mới" styleClass="section-title">
                                        <font><Font name="Segoe UI Bold" size="26.0" /></font>
                                    </Label>
                                    <Label text="Chỉ mất 1 phút để bắt đầu hành trình của bạn" styleClass="muted-text" style="-fx-font-size: 14px;" />
                                </children>
                                <!-- TĂNG KHOẢNG CÁCH TỪ TIÊU ĐỀ XUỐNG FORM -->
                                <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                            </VBox>

                            <!-- TĂNG SPACING TỪ 20 LÊN 25 GIỮA 2 CỘT INPUT -->
                            <HBox spacing="25.0">
                                <children>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <SVGPath content="M 12 12 C 14.21 12 16 10.21 16 8 C 16 5.79 14.21 4 12 4 C 9.79 4 8 5.79 8 8 C 8 10.21 9.79 12 12 12 Z M 12 14 C 9.33 14 4 15.34 4 18 L 4 20 L 20 20 L 20 18 C 20 15.34 14.67 14 12 14 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                            <Label text="Họ và tên" styleClass="row-title-bold" />
                                        </HBox>
                                        <TextField fx:id="txtFullName" prefHeight="45.0" promptText="Vd: Nguyen Van A" styleClass="modern-input" />
                                    </VBox>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <SVGPath content="M 6.62 10.79 C 8.06 13.62 10.38 15.93 13.21 17.38 L 15.41 15.18 C 15.68 14.91 16.08 14.82 16.43 14.94 C 17.55 15.31 18.76 15.51 20 15.51 C 20.55 15.51 21 15.96 21 16.51 L 21 20 C 21 20.55 20.55 21 20 21 C 10.61 21 3 13.39 3 4 C 3 3.45 3.45 3 4 3 L 7.5 3 C 8.05 3 8.5 3.45 8.5 4 C 8.5 5.25 8.7 6.45 9.07 7.57 C 9.18 7.92 9.1 8.31 8.82 8.59 L 6.62 10.79 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                            <Label text="Số điện thoại" styleClass="row-title-bold" />
                                        </HBox>
                                        <TextField fx:id="txtPhoneNumber" prefHeight="45.0" promptText="Vd: 0987654321" styleClass="modern-input" />
                                    </VBox>
                                </children>
                            </HBox>

                            <HBox spacing="25.0">
                                <children>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <SVGPath content="M 20 4 H 4 C 2.9 4 2.01 4.9 2.01 6 L 2 18 C 2 19.1 2.9 20 4 20 H 20 C 21.1 20 22 19.1 22 18 V 6 C 22 4.9 21.1 4 20 4 Z M 20 18 H 4 V 8 L 12 13 L 20 8 V 18 Z M 12 11 L 4 6 H 20 L 12 11 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                            <Label text="Email" styleClass="row-title-bold" />
                                        </HBox>
                                        <TextField fx:id="txtEmail" prefHeight="45.0" promptText="example@gmail.com" styleClass="modern-input" />
                                    </VBox>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="8">
                                            <SVGPath content="M 4 6 H 20 V 18 H 4 V 6 Z M 6 8 V 16 H 18 V 8 H 6 Z M 9 10 H 15 V 12 H 9 V 10 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                            <Label text="Căn cước công dân" styleClass="row-title-bold" />
                                        </HBox>
                                        <TextField fx:id="txtCitizenId" prefHeight="45.0" promptText="Nhập 12 số CCCD" styleClass="modern-input" />
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="10.0">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <SVGPath content="M 19 3 H 5 C 3.9 3 3 3.9 3 5 V 19 C 3 20.1 3.9 21 5 21 H 19 C 20.1 21 21 20.1 21 19 V 5 C 21 3.9 20.1 3 19 3 Z M 12 13 C 10.34 13 9 11.66 9 10 C 9 8.34 10.34 7 12 7 C 13.66 7 15 8.34 15 10 C 15 11.66 13.66 13 12 13 Z M 16 17 H 8 V 16 C 8 14.67 10.67 14 12 14 C 13.33 14 16 14.67 16 16 V 17 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                        <Label text="Tên đăng nhập" styleClass="row-title-bold" />
                                    </HBox>
                                    <TextField fx:id="txtUsername" prefHeight="45.0" promptText="Viết liền không dấu..." styleClass="modern-input" />
                                </children>
                            </VBox>

                            <HBox spacing="25.0">
                                <children>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="8">
                                                <SVGPath content="M 18 8 L 17 8 L 17 6 C 17 3.24 14.76 1 12 1 C 9.24 1 7 3.24 7 6 L 7 8 L 6 8 C 4.9 8 4 8.9 4 10 L 4 20 C 4 21.1 4.9 22 6 22 L 18 22 C 19.1 22 20 21.1 20 20 L 20 10 C 20 8.9 19.1 8 18 8 Z M 12 17 C 10.9 17 10 16.1 10 15 C 10 13.9 10.9 13 12 13 C 13.1 13 14 13.9 14 15 C 14 16.1 13.1 17 12 17 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                                <Label text="Mật khẩu" styleClass="row-title-bold" />
                                            </HBox>
                                            <PasswordField fx:id="txtPassword" prefHeight="45.0" promptText="Mật khẩu" styleClass="modern-input" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="8">
                                                <SVGPath content="M 9 16.2 L 4.8 12 L 3.4 13.4 L 9 19 L 21 7 L 19.6 5.6 L 9 16.2 Z" fill="#7f8c8d" scaleX="0.75" scaleY="0.75"/>
                                                <Label text="Xác nhận" styleClass="row-title-bold" />
                                            </HBox>
                                            <PasswordField fx:id="txtConfirmPassword" prefHeight="45.0" promptText="Nhập lại mật khẩu" styleClass="modern-input" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <!-- TĂNG KHOẢNG CÁCH TRÊN VÀ DƯỚI CHO NÚT BẤM -->
                            <Button maxWidth="Infinity" onAction="#handleRegister" prefHeight="50.0" styleClass="btn-primary" style="-fx-font-size: 16px; -fx-background-radius: 25; -fx-cursor: hand;" text="ĐĂNG KÝ NGAY">
                                <VBox.margin><Insets top="25.0" bottom="15.0" /></VBox.margin>
                            </Button>

                            <HBox alignment="CENTER" spacing="8.0">
                                <children>
                                    <Label text="Đã có tài khoản?" styleClass="row-title-bold" />
                                    <Hyperlink onAction="#goToLogin" style="-fx-text-fill: #3b5998; -fx-font-weight: bold; -fx-font-size: 14px;" text="Đăng nhập" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </StackPane>

        </VBox>
    </children>
</HBox>