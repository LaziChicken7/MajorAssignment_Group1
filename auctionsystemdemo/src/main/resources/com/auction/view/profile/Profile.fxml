<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.profile.ProfileController" spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT" spacing="5" styleClass="title-container">
        <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
        <Label text="Profile của tôi" styleClass="back-title" />
    </HBox>

    <!-- Đã xóa inline style, dùng class card và profile-card -->
    <HBox styleClass="card, profile-card" spacing="40" alignment="CENTER_LEFT">
        <VBox alignment="CENTER" spacing="15">
            <!-- Đã dùng class cho Avatar -->
            <StackPane styleClass="avatar-placeholder" prefWidth="200" prefHeight="200">
                <Label fx:id="lblAvatarPlaceholder" text="👤" styleClass="avatar-icon-text"/>
                <ImageView fx:id="imgAvatar" fitWidth="200" fitHeight="200" preserveRatio="false"/>
            </StackPane>

            <Button text="Tải ảnh lên" onAction="#handleUploadAvatar" styleClass="btn-primary, btn-pill" />
        </VBox>

        <GridPane hgap="20" vgap="15" HBox.hgrow="ALWAYS">
            <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="profile-label"/>
            <!-- Dùng modern-input cho ô nhập bình thường, readonly-input cho ô bị khóa -->
            <TextField fx:id="txtUsername" editable="false" styleClass="modern-input, readonly-input" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="400"/>

            <Label text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="profile-label"/>
            <TextField fx:id="txtFullName" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="profile-label"/>
            <TextField fx:id="txtEmail" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Số điện thoại:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="profile-label"/>
            <TextField fx:id="txtPhone" editable="false" styleClass="modern-input, readonly-input" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="CCCD:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="profile-label"/>
            <TextField fx:id="txtCitizenId" editable="false" styleClass="modern-input, readonly-input" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Mật khẩu mới:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="profile-label"/>
            <!-- Chuyển PasswordField về class modern-input -->
            <PasswordField fx:id="txtPassword" promptText="Bỏ trống nếu không muốn đổi mật khẩu" styleClass="modern-input" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <Button text="Xác nhận chỉnh sửa" onAction="#handleUpdateProfile" styleClass="btn-primary, btn-large-pill" />
            </HBox>
        </GridPane>
    </HBox>

    <HBox alignment="CENTER" spacing="20">
        <!-- Nút Admin Control giữ nguyên -->
        <Button fx:id="btnAdminControl" text="⚙ Trung tâm điều khiển" visible="false" managed="false" onAction="#handleOpenAdminControl" styleClass="btn-warning, btn-large-pill"/>

        <!-- NÚT MỚI THÊM: Yêu cầu lên Seller -->
        <Button fx:id="btnRequestSeller" text="🚀 Yêu cầu lên Seller" visible="false" managed="false" onAction="#handleRequestSeller" styleClass="btn-primary, btn-large-pill" style="-fx-background-color: #2ecc71;"/>

        <!-- Nút Đăng xuất giữ nguyên -->
        <Button text="Đăng xuất" onAction="#handleLogout" styleClass="btn-danger, btn-large-pill"/>
    </HBox>
</VBox>