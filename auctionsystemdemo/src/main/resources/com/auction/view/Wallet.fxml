<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="walletRoot" spacing="20" style="-fx-background-color: transparent;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.auction.controller.WalletController">

    <!-- HEADER ĐÃ ĐƯỢC CHUẨN HÓA (Dùng title-container vì là trang chính) -->
    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="title-container">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label styleClass="back-title" text="Ví tiền của tôi" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button onAction="#handleDeposit" styleClass="btn-success" text="Nạp tiền">
            <font>
               <Font size="14.0" />
            </font></Button>
            <Button onAction="#handleWithdraw" styleClass="btn-danger" text="Rút tiền">
            <font>
               <Font size="14.0" />
            </font></Button>
        </HBox>
    </HBox>

    <!-- THẺ VISA & THÔNG TIN TÀI KHOẢN -->
    <HBox alignment="CENTER_LEFT" spacing="30" styleClass="card">
        <AnchorPane prefHeight="200" prefWidth="350" style="-fx-background-color: #0A439D; -fx-background-radius: 15;">
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="VISA" textFill="white" AnchorPane.bottomAnchor="15" AnchorPane.rightAnchor="20" />
        </AnchorPane>

        <VBox alignment="CENTER_LEFT" spacing="15" HBox.hgrow="ALWAYS">
            <HBox spacing="10">
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Số tài khoản:" />
                <Label fx:id="lblBankAccount" style="-fx-font-size: 20px; -fx-text-fill: #333;" text="Đang tải..." />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="150" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Số dư" />
                <TextField fx:id="balanceField" editable="false" prefWidth="210" style="-fx-background-radius: 20; -fx-font-size: 16px; -fx-alignment: center;" text="****** VND" />
                <Label fx:id="eyeIconText" onMouseClicked="#toggleBalanceVisibility" style="-fx-font-size: 16px; -fx-text-fill: #0A439D; -fx-font-weight: bold; -fx-cursor: hand;" text="Hiện" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label prefWidth="150" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Số dư đóng băng" />
                <Label fx:id="lblFrozenBalance" alignment="CENTER" prefWidth="250" style="-fx-font-size: 16px;" styleClass="auction-price" text="0 VND" />
            </HBox>
        </VBox>
    </HBox>

    <!-- LỊCH SỬ GIAO DỊCH -->
    <VBox fx:id="historySection" spacing="20" VBox.vgrow="ALWAYS">
        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Giao dịch thành công" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleSuccessfulTransaction" styleClass="btn-primary" text="Xem thêm" />
                </HBox>
                <VBox fx:id="vboxSuccess" spacing="10" styleClass="card" />
            </VBox>

            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Giao dịch ko thành công" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleFailureTransaction" styleClass="btn-primary" text="Xem thêm" />
                </HBox>
                <VBox fx:id="vboxFailed" spacing="10" styleClass="card" />
            </VBox>
        </HBox>
    </VBox>
</VBox>
