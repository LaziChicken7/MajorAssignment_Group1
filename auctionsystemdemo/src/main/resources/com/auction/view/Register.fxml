<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="750.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.RegisterController">
    <children>
        <!-- BÊN TRÁI: PANEL THƯƠNG HIỆU -->
        <VBox alignment="CENTER" prefWidth="350.0" spacing="20.0" style="-fx-background-color: #0A439D;">
            <children>
                <Label text="Hệ thống đấu giá trực tuyến" textFill="white">
                    <font><Font name="System Bold" size="26.0" /></font>
                </Label>
                <Label text="Tham gia cộng đồng đấu giá ngay" textFill="white" />
            </children>
        </VBox>

        <!-- BÊN PHẢI: FORM ĐĂNG KÝ -->
        <VBox alignment="CENTER" prefWidth="550.0" spacing="12.0" style="-fx-background-color: white;">
            <padding><Insets left="60.0" right="60.0" /></padding>
            <children>
                <Label text="Tạo tài khoản mới">
                    <font><Font name="System Bold" size="28.0" /></font>
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </Label>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Họ và tên" />
                        <TextField fx:id="txtFullName" prefHeight="35.0" promptText="Nhập họ và tên..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Email" />
                        <TextField fx:id="txtEmail" prefHeight="35.0" promptText="example@gmail.com" style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <!-- THÊM Ô SỐ ĐIỆN THOẠI -->
                <VBox spacing="5.0">
                    <children>
                        <Label text="Số điện thoại" />
                        <TextField fx:id="txtPhoneNumber" prefHeight="35.0" promptText="Nhập số điện thoại..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <!-- THÊM Ô CCCD -->
                <VBox spacing="5.0">
                    <children>
                        <Label text="Số CCCD" />
                        <TextField fx:id="txtCitizenId" prefHeight="35.0" promptText="Nhập số Căn cước công dân..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Tên đăng nhập" />
                        <TextField fx:id="txtUsername" prefHeight="35.0" promptText="Chọn tên đăng nhập..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Mật khẩu" />
                        <PasswordField fx:id="txtPassword" prefHeight="35.0" promptText="Nhập mật khẩu..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Xác nhận mật khẩu" />
                        <PasswordField fx:id="txtConfirmPassword" prefHeight="35.0" promptText="Nhập lại mật khẩu..." style="-fx-background-radius: 8;" />
                    </children>
                </VBox>

                <Button maxWidth="Infinity" onAction="#handleRegister" prefHeight="45.0"
                        style="-fx-background-color: #0A439D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;"
                        text="ĐĂNG KÝ NGAY">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Button>

                <HBox alignment="CENTER" spacing="5.0">
                    <children>
                        <Label text="Đã có tài khoản?" />
                        <Hyperlink onAction="#goToLogin" text="Đăng nhập" style="-fx-text-fill: #0A439D; -fx-font-weight: bold;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>