<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionController" spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT">
        <HBox spacing="5" styleClass="title-container">
            <SVGPath content="M 16 4 L 6 14 L 16 24" styleClass="back-icon" />
            <Label text="Đấu giá" styleClass="back-title" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Button text="🔄 Làm mới" onAction="#loadData" styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 8 20; -fx-font-size: 14px;"/>

            <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #3b5998; -fx-background-radius: 20; -fx-padding: 6 20;">
                <Label text="Số dư:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                <Label fx:id="lblBalance" text="Đang tải..." style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
            </HBox>
        </HBox>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
        <Label text="Lọc trạng thái:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333;"/>
        <ComboBox fx:id="cbFilter" prefWidth="200" style="-fx-background-color: #f1f2f6; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 2 10;"/>

        <Region HBox.hgrow="ALWAYS" />

        <Label text="Sắp xếp thời gian:" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333;"/>
        <ComboBox fx:id="cbSort" prefWidth="240" style="-fx-background-color: #f1f2f6; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 2 10;"/>
    </HBox>

    <ListView fx:id="auctionListView" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />

</VBox>