<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<!-- THẺ GỐC Y HỆT WALLET (Đã xóa padding thừa) -->
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.TransactionController"
      spacing="20" style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT">
        <Label text="&lt; Giao dịch thành công" onMouseClicked="#handleBackToWallet"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;"
                VBox.vgrow="ALWAYS">
        <content>
            <!-- Sử dụng styleClass="card" chuẩn của hệ thống -->
            <VBox fx:id="successContainer" spacing="15" styleClass="card" />
        </content>
    </ScrollPane>
</VBox>